100 DEF FNLW(X)=MAX(1,4\(2^(X\2)))
110 DEF FNR$(N)=STR$(RM0+(RV0-RM0)*N/NM)
120 DEF FNG$(N)=STR$(GM0+(GV0-GM0)*N/NM)
130 DEF FNB$(N)=STR$(BM0+(BV0-BM0)*N/NM)
140 DEG : SCREEN : CLG
150 MOVE WIDTH\2,HEIGHT\10
160 NM=12 : N=0 : F=1/SQR(2)
170 RM0=139 : GM0=69 : BM0=19 'Brown
180 RV0=34 : GV0=255 : BV0=34 'Green
190 DIM A(NM),L(NM),X(NM),Y(NM)
200 A(N)=0 : L(N)=HEIGHT\4 : X(N)=XPOS : Y(N)=YPOS
210 GOSUB 230
220 END
230 REM Subroutine that simulates recursion
240 INK FNR$(N)+","+FNG$(N)+","+FNB$(N)
250 PENWIDTH FNLW(N)
260 DRAW X(N)+L(N)*SIN(A(N)),Y(N)+L(N)*COS(A(N)) : FRAME
270 N=N+1 : IF N<NM THEN X(N)=XPOS:Y(N)=YPOS ELSE 340
280 '25° on the right branch for a more "organic" look
290 A(N)=A(N-1)+25 : L(N)=L(N-1)*F
300 GOSUB 230
310 A(N)=A(N-1)-45
320 MOVE X(N),Y(N)
330 GOSUB 230
340 N=N-1 : MOVE X(N),Y(N)
350 RETURN

