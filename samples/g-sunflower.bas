100 PTS=50 : Phi=2.39996323
110 DEF FNMYRGB(H)=65536*INT(255*MAX(0,MIN(1,ABS(6*H-3)-1)))+256*INT(255*MAX(0,MIN(1,2-ABS(6*H-2))))+INT(255*MAX(0,MIN(1,2-ABS(6*H-4))))
120 T=0 : ORIGIN WIDTH\2,HEIGHT\2 : PENWIDTH 4
130 WHILE 1=1
140   CLG
150   FOR I=0 TO PTS-1
160     R0=4*SQR(I)
170     H=R0/200+T*0.05
180     C=FNMYRGB(H-INT(H))
190     R=R0+30*SIN(T+I*0.04)
200     Z=I*Phi+T
210     X=R*COS(Z) : Y=R*SIN(Z)
220     PLOT X,Y,C
230   NEXT I
240   T=T+0.04 : FRAME 60
250 WEND
