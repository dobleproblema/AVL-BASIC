10 CLG : BIGFONT : DEG
20 T$="COPYRIGHT 2025 JOSE ANTONIO AVILA . "
30 T=P=1 : L=LEN(T$)
40 T1=TIME
50 FOR C=1 TO 1000
60 CLG
70 FOR X=T TO 360+T STEP 10
80 MOVE WIDTH\2+SIN(X)*200,HEIGHT\2+COS(X)*200
90 C$=MID$(T$,P,1)
100 P=(P+1) MOD L
110 LDIR -X : GDISP C$,1,-1
120 NEXT
130 FRAME : T=T+9
140 NEXT C
150 PRINT "Elapsed time";TIME-T1

