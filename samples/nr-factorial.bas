10 S=285 : R=9 : D=10^R
20 F$="0"+STRING$(R-1,"#")
30 DIM F(S)
40 N=100 'S=285 -> N up to 999
50 T1=TIME
60 L=0 : F(1)=V=1
70 FOR C=2 TO N
80 FOR T=1 TO V
90 B=F(T)*C+L : L=B\D
100 F(T)=B MOD D
110 NEXT T
120 IF L THEN F(T)=L:V=T:L=0
130 NEXT C
140 T1=TIME-T1
150 PRINT USING "#";T1;" sec."
160 PRINT STR$(F(T-1));
170 FOR K=T-2 TO 1 STEP -1 : PRINT USING F$; F(K); : NEXT
180 END

