100 REM Sierpinski triangle
110 DEG : CLG
120 P=6 : L=500 : A=N=0 : DIM C(10)
130 X=(WIDTH-L)/2 : Y=(HEIGHT-SQR(3)*L/2)/2
140 MOVE X,Y
150 GOSUB 170
160 END
170 IF N=P THEN 260 ELSE C(N)=1
180 X=X+L*COS(A) : Y=Y+L*SIN(A)
190 IF N=0 OR C(N)=2 THEN DRAW X,Y ELSE MOVE X,Y
200 A=(A+120) MOD 360
210 L=L/2 : N=N+1
220 GOSUB 170
230 L=L*2 : N=N-1
240 C(N)=C(N)+1
250 IF C(N)<=3 THEN 180
260 RETURN

