100 REM  RETRO ZOOMER-ROTATOR FOR AVL BASIC
130 IMG$="assets/anime.png" '640x480 PNG LOADED WITH BLOAD
140 W=640 : H=480
150 S=3 '16=FOR PYTHON :-), 8=FAST BUT CHUNKY, 4 or 3=GOOD COMPROMISE, 2=FOR FAST CPUS, 1=FOR *REALLY* FAST CPUS
170 NX=W\S : NY=H\S
180 DIM PIX(NX-1,NY-1)
190 SCREEN : MODE 640
200 PAPER 0 : CLG
210 DEG
220 HS=S/2 : SM1=S-1 : IS=1/S : INX=1/NX : INY=1/NY
230 REM LOAD THE ORIGINAL IMAGE AND SAMPLE IT INTO A BLOCK TEXTURE
240 BLOAD IMG$
250 FOR J=0 TO NY-1
260   Y=J*S+HS
270   FOR I=0 TO NX-1
280     X=I*S+HS
290     PIX(I,J)=TEST(X,Y)
300   NEXT I
310 NEXT J
320 REM PARAMETERS
330 CX=(W-1)/2 : CY=(H-1)/2
340 DX0=HS-CX : DY0=HS-CY
350 T0=TIME
360 FCOUNT=0
370 TLAST=TIME
380 FPS=0
390 REM MAIN LOOP
400 T=TIME-T0
410 REM ROTATION ANGLE
420 A=T*25
430 REM PULSING ZOOM
440 Z=0.5+2*(1+SIN(T*60))^2 'Z=P1+P2*(1+SIN(... P1=MIDDLE POINT, P2=RANGE
450 REM DINAMIC OFFSET FOR LIVELIER MOTION OR FIXED VALUES
460 UOFF=180*SIN(T*137) '0
470 VOFF=130*COS(T*113) '0
480 IZ=1/Z : CA=COS(A) : SA=SIN(A)
490 DSU=CA*IZ : DSV=-SA*IZ
500 RSU=SA*IZ : RSV=CA*IZ
510 U0=((DX0*CA+DY0*SA)*IZ+CX+UOFF)*IS
520 V0=((-DX0*SA+DY0*CA)*IZ+CY+VOFF)*IS
530 Y0=0
540 FOR J=0 TO NY-1
550   Y1=Y0+SM1
560   U=U0 : V=V0 : X0=0
570   FOR I=0 TO NX-1
580     FRECTANGLE X0,Y0,X0+SM1,Y1,PIX(INT(U-NX*INT(U*INX)),INT(V-NY*INT(V*INY)))
590     U=U+DSU : V=V+DSV : X0=X0+S
600   NEXT I
610   U0=U0+RSU : V0=V0+RSV : Y0=Y0+S
620 NEXT J
630 REM --- FPS COUNTER ---
640 FCOUNT=FCOUNT+1
650 IF TIME-TLAST>=0.5 THEN
660   FPS=FCOUNT/(TIME-TLAST)
670   FCOUNT=0
680   TLAST=TIME
690 END IF
700 REM OPTIONAL DEMO-STYLE LABEL
710 SMALLFONT : INK 18 : LOCATE 1,1
720 GPRINT "AVL-BASIC ZOOMER-ROTATOR  FPS: ";USING ".0";FPS;"  ESC=EXIT"
730 FRAME
740 IF KEYDOWN(27) THEN SCREEN CLOSE:END
750 GOTO 400
