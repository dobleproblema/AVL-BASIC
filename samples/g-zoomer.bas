10 REM ============================================================
20 REM  ZOOMER-ROTATOR RETRO PARA AVL BASIC
30 REM  PNG 640x480 CARGADO CON BLOAD
40 REM  ESC PARA SALIR
50 REM ============================================================
60 IMG$="assets/anime.png"
70 W=640 : H=480
80 S=4 : REM 8=CHUNKY RAPIDO, 4=MAS FINO, 16=MUY RETRO
90 NX=W\S : NY=H\S
100 DIM PIX(NX-1,NY-1)
110 SCREEN : MODE 640
120 PAPER 0 : CLG
130 RAD
135 HS=S/2 : SM1=S-1 : IS=1/S : INX=1/NX : INY=1/NY
140 REM ------------------------------------------------------------
150 REM CARGAR IMAGEN ORIGINAL Y MUESTREARLA A UNA TEXTURA DE BLOQUES
160 REM ------------------------------------------------------------
170 BLOAD IMG$
180 FOR J=0 TO NY-1
190   Y=J*S+HS
200   FOR I=0 TO NX-1
210     X=I*S+HS
220     PIX(I,J)=TEST(X,Y)
230   NEXT I
240 NEXT J
250 REM ------------------------------------------------------------
260 REM PARAMETROS
270 REM ------------------------------------------------------------
280 CX=(W-1)/2 : CY=(H-1)/2
285 DX0=HS-CX : DY0=HS-CY
290 T0=TIME
295 FCOUNT=0
296 TLAST=TIME
297 FPS=0
300 REM ------------------------------------------------------------
310 REM BUCLE PRINCIPAL
320 REM ------------------------------------------------------------
330 T=TIME-T0
340 REM ANGULO DE ROTACION
350 A=T*0.43633231299858
360 REM ZOOM PULSANTE
370 Z=0.5+0.5*(1+SIN(T*1.0471975511966))^2 'Z=1.1+1*SIN(T*1.30899693899575)
380 REM DESPLAZAMIENTO DE LA TEXTURA PARA DAR MAS VIDA
390 UOFF=180*SIN(T*2.39110107523223) '23 -> 137
400 VOFF=130*COS(T*1.97222205475359) '19 -> 113
410 IZ=1/Z : CA=COS(A) : SA=SIN(A)
420 DSU=CA*IZ : DSV=-SA*IZ
430 RSU=SA*IZ : RSV=CA*IZ
440 U0=((DX0*CA+DY0*SA)*IZ+CX+UOFF)*IS
450 V0=((-DX0*SA+DY0*CA)*IZ+CY+VOFF)*IS
460 Y0=0
470 FOR J=0 TO NY-1
480   Y1=Y0+SM1
490   U=U0 : V=V0 : X0=0
500   FOR I=0 TO NX-1
510     SI=INT(U-NX*INT(U*INX))
520     SJ=INT(V-NY*INT(V*INY))
530     CLM=PIX(SI,SJ)
540     FRECTANGLE X0,Y0,X0+SM1,Y1,CLM
550     U=U+DSU : V=V+DSV : X0=X0+S
560   NEXT I
570   U0=U0+RSU : V0=V0+RSV : Y0=Y0+S
580 NEXT J
671 REM --- CONTADOR FPS ---
672 FCOUNT=FCOUNT+1
673 IF TIME-TLAST>=0.5 THEN
674   FPS=FCOUNT/(TIME-TLAST)
675   FCOUNT=0
676   TLAST=TIME
677 END IF
680 REM ROTULO OPCIONAL ESTILO DEMO
682 LOCATE 1,1
683 DISP "AVL-BASIC ZOOMER-ROTATOR FPS: " + DEC$(FPS,".0") + " ESC=SALIR",18,-1
710 FRAME
720 IF KEYDOWN(27) THEN SCREEN CLOSE:END
730 GOTO 330
