100 REM MACHIN ALGORITHM TO CALCULATE PI
105 P=1000 'INPUT "DIGITS: ",P
110 L=9 'Safe 9-digit blocks: keeps R*F+B4(A) exact (no rounding) up to 1,000,000 decimal digits
115 F=10^L : G=(P+1)\L : F$="0"+STRING$(L-1,"#")+" "
120 DIM B1(G),B2(G),B3(G),B4(G)
125 T1=TIME
130 P=5 : GOSUB 900
135 P=16 : GOSUB 600
140 P=239 : GOSUB 900
145 P=4 : GOSUB 500
150 GOSUB 300
155 T2=TIME
160 REM PRINT
165 FOR A=0 TO G
170 PRINT USING F$;B1(A);
175 IF A>0 AND A MOD 8 = 7 THEN PRINT
180 NEXT A
185 PRINT : PRINT USING "#.###";T2-T1;" SEG."
190 END
200 REM B1+B2->B1
205 K=0 : D=0
210 FOR A=G TO H STEP -1
215 D=B1(A)+B2(A)+K
220 IF D>=F THEN D=D-F:K=1 ELSE K=0
225 B1(A)=D
230 NEXT A
235 IF K=0 THEN 270
240 FOR A=H-1 TO 0 STEP -1
245 D=B1(A)+K
250 IF D>=F THEN D=D-F:K=1 ELSE K=0
255 B1(A)=D
260 IF K=0 THEN A=0
265 NEXT A
270 RETURN
300 REM B3-B2->B1
305 K=0
310 FOR A=G TO 0 STEP -1
315 D=B3(A)-B2(A)-K
320 IF D<0 THEN D=D+F:K=1 ELSE K=0
325 B1(A)=D
330 NEXT A
335 RETURN
400 REM B1-B2->B1
405 K=0
410 FOR A=G TO H STEP -1
415 D=B1(A)-B2(A)-K
420 IF D<0 THEN D=D+F:K=1 ELSE K=0
425 B1(A)=D
430 NEXT A
435 IF K=0 THEN 470
440 FOR A=H-1 TO 0 STEP -1
445 D=B1(A)-K
450 IF D<0 THEN D=D+F:K=1 ELSE K=0
455 B1(A)=D
460 IF K=0 THEN A=0
465 NEXT A
470 RETURN
500 REM B1*F1->B2
505 K=0
510 FOR A=G TO 0 STEP -1
515 IF B1(A)=0 AND K=0 THEN 535
520 D=B1(A)*P+K
525 IF D>=F THEN K=D\F:D=D MOD F ELSE K=0
530 B2(A)=D
535 NEXT A
540 RETURN
600 REM B1*F1->B3, B1=0
605 K=0
610 FOR A=G TO 0 STEP -1
615 IF B1(A)=0 AND K=0 THEN 635
620 D=B1(A)*P+K
625 IF D>=F THEN K=D\F:D=D MOD F ELSE K=0
630 B3(A)=D : B1(A)=0
635 NEXT A
640 RETURN
700 REM B4/F1->B2
705 R=0 : O=H : H=G+1
710 FOR A=O TO J-1 : B2(A)=0 : NEXT A
715 FOR A=J TO G
720 IF B4(A)=0 AND R=0 THEN B2(A)=0:GOTO 735
725 D=R*F+B4(A)
730 C=D\P : R=D MOD P : B2(A)=C : IF C THEN IF H>G THEN H=A
735 NEXT A : RETURN
750 REM B4/F1->B4, Z=1 IF B4=0
755 Z=1 : O=J : J=G+1 : R=0
760 FOR A=O TO G
765 IF B4(A)=0 AND R=0 THEN 790
770 D=R*F+B4(A) : C=D\P : R=D MOD P
775 B4(A)=C : IF C THEN Z=0:IF J>G THEN J=A
790 NEXT A
795 RETURN
800 REM 1/F->B4
805 R=F : D=0 : J=G+1
810 FOR A=0 TO G
815 B4(A)=R\P
820 IF B4(A) THEN IF J>G THEN J=A
825 R=(R MOD P)*F
830 NEXT A
835 RETURN
900 REM ATAN(1/F1)->B1
905 N=1 : Q=P*P
910 GOSUB 800
915 P=N : GOSUB 700
920 GOSUB 200
925 P=Q : GOSUB 750
930 N=N+2
935 IF Z THEN 965
940 P=N : GOSUB 700
945 GOSUB 400
950 P=Q : GOSUB 750
955 N=N+2
960 IF Z=0 THEN 915
965 RETURN
970 END
