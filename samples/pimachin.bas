100 REM MACHIN ALGORITHM TO CALCULATE PI
110 P=1000 'INPUT "DIGITS: ",P
120 L=11 : F=10^L : G=(P+1)\L
130 DIM B1(G),B2(G),B3(G),B4(G)
140 T1=TIME
150 P=5 : GOSUB 900
160 P=16 : GOSUB 610
170 P=239 : GOSUB 900
180 P=4 : GOSUB 600
190 GOSUB 500
200 T2=TIME
210 REM PRINT
220 FOR A=0 TO G
230 PRINT USING "0########## ";B1(A);
240 IF A>0 AND A MOD 6 = 5 THEN PRINT
250 NEXT A
260 PRINT : PRINT USING "#.###";T2-T1;" SEG."
270 STOP
300 REM B4=0?
310 Z=1
320 FOR A=G TO 0 STEP -1
330 IF B4(A) THEN Z=0:GOTO 350
340 NEXT A
350 RETURN
400 REM B1+B2->B1
410 K=0 : D=0
420 FOR A=G TO 0 STEP -1
430 D=B1(A)+B2(A)+K
440 IF D>F THEN D=D-F:K=1 ELSE K=0
450 B1(A)=D
460 NEXT A
470 RETURN
500 REM B1-B2->B1 O B3-B2->B1
505 T=1 : GOTO 520
510 T=0
520 K=0
530 FOR A=G TO 0 STEP -1
540 IF T THEN D=B3(A)-B2(A)-K ELSE D=B1(A)-B2(A)-K
550 IF D<0 THEN D=D+F:K=1 ELSE K=0
560 B1(A)=D
570 NEXT A
580 RETURN
600 REM B1*F1->B2 O B1*F1->B3, B1=0
605 T=0 : GOTO 620
610 T=1
620 K=0
630 FOR A=G TO 0 STEP -1
640 IF B1(A)=K THEN 680
650 D=B1(A)*P+K
660 IF D>F THEN K=D\F:D=D MOD F ELSE K=0
670 IF T THEN B3(A)=D:B1(A)=0 ELSE B2(A)=D
680 NEXT A
690 RETURN
700 REM B4/F1->B2 O B4/F1->B4
705 T=0 : GOTO 720
710 T=1
720 R=0
730 FOR A=0 TO G
740 IF B4(A)=R THEN B2(A)=0:GOTO 780
750 D=R*F+B4(A)
760 C=D\P : R=D MOD P
770 IF T THEN B4(A)=C ELSE B2(A)=C
780 NEXT A
790 RETURN
800 REM 1/F->B4
810 R=F : D=0
820 FOR A=0 TO G
830 B4(A)=R\P
840 R=(R MOD P)*F
850 NEXT A
860 RETURN
900 REM ATAN(1/F1)->B1
910 S=1 : N=1 : Q=P*P
920 GOSUB 800
930 P=N : GOSUB 700
940 ON S GOSUB 400,510
950 P=Q : GOSUB 710
960 N=N+2 : S=3-S
970 GOSUB 300 : IF Z=0 THEN 930
980 RETURN
990 END

