100 DEF FNSHAPE(SHAPE$,VALUE)
110   MOVE I,VALUE
120   IF SHAPE$="W" THEN
130     MOVER 0,0.25 : DRAWR 0,-0.5
140     MOVER 0.25,0.25 : DRAWR -0.5,0
150   ELSEIF SHAPE$="M" THEN
160     DRAWR 0.5,0 : DRAWR 0,-0.5
170     DRAWR -0.5,0 : DRAWR 0,0.5
180   ENDIF
200 FNEND
210 REM *100-METER FREESTYLE SUMMER OLYMPICS 1948-1976*
220 SCREEN : CLG
230 B=50
250 SCALE 1944,1978,48,69,B
255 CROSSAT 1944,48
260 XAXIS 4,,,,1,4
270 YAXIS 1,,,,2
280 FOR I=1948 TO 1976 STEP 4
290   READ M
300   X=FNSHAPE("M",M)
310   READ W
320   X=FNSHAPE("W",W)
330 NEXT I
340 DATA 57.2, 66.3, 57.4, 66.8, 55.4, 62, 55.2, 61.2
350 DATA 53.4, 59.5, 52.2, 60, 51.22, 58.59, 49.99, 55.65
360 END

