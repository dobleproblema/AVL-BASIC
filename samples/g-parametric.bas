100 DEF FNX(T)=SIN(5*T)*COS(2*T)
110 DEF FNY(T)=SIN(3*T)*SIN(2*T)
120 DEF FNR(T)=INT(127.5 + 127.5 * SIN(T))
130 DEF FNG(T)=INT(127.5 + 127.5 * SIN(T + 2*PI/3))
140 DEF FNB(T)=INT(127.5 + 127.5 * SIN(T + 4*PI/3))
150 B=10 'Border discarded at each end so the labels fit
180 P=0.01
190 SCREEN : CLG
200 SCALE -4/3,4/3,-1,1,B
210 ON ERROR GOTO 330
215 T1=TIME
220 PENWIDTH 4
230 PLOT FNX(0),FNY(0)
240 FOR T=0 TO 2*PI STEP P
250 INK RGB$(FNR(T),FNG(T),FNB(T))
260 X=FNX(T) : Y=FNY(T)
270 DRAW X,Y
280 NEXT
285 PRINT "Elapsed time:";TIME-T1
290 INK 1
300 XAXIS 0,,,-1
310 YAXIS 0,,,-1
320 END
330 RESUME NEXT

