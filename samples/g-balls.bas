100 MODE 640 : SCREEN : PAPER 0 : CLG : SMALLFONT
110 CX=WIDTH\2 : CY=HEIGHT\2
120 NS=50 : IF NS<1 THEN NS=1
130 R=9 : S=2*R+1 : B=16 : BT=INT(1.75*B) : F9=0
140 DIM S$(NS),BG$(NS),NBG$(NS),X(NS),Y(NS),OX(NS),OY(NS),DX(NS),DY(NS)
150 ML=2*LEN(TRIM$(STR$(NS)))+5 : MSGCLR$=SPACE$(ML)
160 TX=264 : TY=20 : TMSG=0 : MSG$=MSGCLR$ : MSGDIR=0
170 GOSUB 1220
180 BIGFONT
190 GOSUB 1040
200 T1=TIME
210 GOSUB 1000
220 FOR I=1 TO NS : BG$(I)=SPRITE$(X(I),Y(I),X(I)+S-1,Y(I)+S-1) : NEXT I
230 REM First pass with id: leaves the initial image ON SCREEN AND seeds the map/register FOR SPRITE MOVE + HITID
240 COLMODE 0 : FOR I=1 TO NS : SPRITE S$(I),X(I),Y(I),0,I : NEXT I
250 REM ===== Main loop without CLG per frame (dirty redraw per sprite) =====
260 FOR I=1 TO NS : OX(I)=X(I) : OY(I)=Y(I) : SPRITE BG$(I),OX(I),OY(I) : NEXT I
270 COLRESET : COLMODE 1 : COLCOLOR 1
280 FOR I=1 TO NS : GOSUB 430 : NEXT I
290 REM Resolve sprite-sprite collisions in BASIC before drawing to avoid order bias
300 FOR I=1 TO NS-1
310   FOR J=I+1 TO NS : GOSUB 490 : NEXT J
320 NEXT I
330 COLMODE 0
340 REM Capture NEW background before drawing sprites to avoid "contamination"
350 FOR I=1 TO NS : NBG$(I)=SPRITE$(X(I),Y(I),X(I)+S-1,Y(I)+S-1) : NEXT I
360 FOR I=1 TO NS : SPRITE MOVE I,X(I),Y(I),0 : BG$(I)=NBG$(I) : NEXT I
370 IF TMSG>0 THEN TMSG=TMSG-1 : IF TMSG=0 THEN MSG$=MSGCLR$ : MSGDIR=1
380 IF MSGDIR THEN MOVE TX,TY : GDISP MSG$,15,0 : MSGDIR=0
390 FRAME
400 F9=F9+1 : IF TIME-T1>10 THEN PRINT "FPS:"+STR$(F9/10) : F9=0 : T1=TIME
410 GOTO 260
430 REM Move sprite I and bounce against the border by color (HITTEST)
440 OLDX=X(I) : X(I)=X(I)+DX(I)
450 SPRITE HITTEST S$(I),X(I),Y(I),0,I : IF HITCOLOR<>0 THEN X(I)=OLDX : DX(I)=-DX(I)
460 OLDY=Y(I) : Y(I)=Y(I)+DY(I)
470 SPRITE HITTEST S$(I),X(I),Y(I),0,I : IF HITCOLOR<>0 THEN Y(I)=OLDY : DY(I)=-DY(I)
480 RETURN
490 REM Geometric collision I<->J: separate sprites AND bounce ON the dominant axis
500 AX=X(I)-X(J) : IF ABS(AX)>2*R THEN RETURN
510 AY=Y(I)-Y(J) : IF ABS(AY)>2*R THEN RETURN
520 IF AX*AX+AY*AY>4*R*R THEN RETURN
530 IF ABS(AX)>=ABS(AY) THEN GOSUB 610 ELSE GOSUB 710
540 OX(I)=X(I) : OY(I)=Y(I) : OX(J)=X(J) : OY(J)=Y(J)
550 MSG$=CHR$(64+J)+" <-> "+CHR$(64+I)
560 TMSG=180 : MSGDIR=1
570 RETURN
610 SX=1 : IF AX<0 THEN SX=-1
620 IF AX=0 THEN SX=1 : IF DX(I)-DX(J)<0 THEN SX=-1
630 T=DX(I) : DX(I)=DX(J) : DX(J)=T
640 N=0
650 WHILE (X(I)-X(J))*(X(I)-X(J))+(Y(I)-Y(J))*(Y(I)-Y(J))<=4*R*R AND N<S+2
660   X(I)=X(I)+SX : X(J)=X(J)-SX
670   K=I : GOSUB 1180 : K=J : GOSUB 1180
680   N=N+1
690 WEND
700 RETURN
710 SY=1 : IF AY<0 THEN SY=-1
720 IF AY=0 THEN SY=1 : IF DY(I)-DY(J)<0 THEN SY=-1
730 T=DY(I) : DY(I)=DY(J) : DY(J)=T
740 N=0
750 WHILE (X(I)-X(J))*(X(I)-X(J))+(Y(I)-Y(J))*(Y(I)-Y(J))<=4*R*R AND N<S+2
760   Y(I)=Y(I)+SY : Y(J)=Y(J)-SY
770   K=I : GOSUB 1180 : K=J : GOSUB 1180
780   N=N+1
790 WEND
800 RETURN
1000 REM Fixed background: DRAW it only once
1010 CLG : INK 1 : RECTANGLE B,BT,WIDTH-1-B,HEIGHT-1-B
1020 FTRIANGLE CX-100,CY-80,CX+100,CY-80,CX,CY+80,1
1030 RETURN
1040 REM Initialize positions spread along the inner border of the field
1050 LX=B+2 : RX=WIDTH-B-S-2 : IF RX<LX THEN RX=LX
1060 TY0=BT+2 : BY0=HEIGHT-B-S-2 : IF BY0<TY0 THEN BY0=TY0
1070 W=RX-LX : H=BY0-TY0 : P=2*(W+H) : IF P<1 THEN P=1
1080 FOR I=1 TO NS
1090   D=((I-1)*P)\NS
1100   IF D<W THEN X(I)=LX+D : Y(I)=TY0 : GOTO 1140
1110   IF D<W+H THEN X(I)=RX : Y(I)=TY0+(D-W) : GOTO 1140
1120   IF D<2*W+H THEN X(I)=RX-(D-W-H) : Y(I)=BY0 : GOTO 1140
1130   X(I)=LX : Y(I)=BY0-(D-2*W-H)
1140   DX(I)=1+(I MOD 3) : IF I MOD 2=0 THEN DX(I)=-DX(I)
1150   DY(I)=1+((I+1) MOD 3) : IF (I\2) MOD 2=1 THEN DY(I)=-DY(I)
1160 NEXT I
1170 RETURN
1180 REM Adjust sprite K to the usable area
1190 IF X(K)<B THEN X(K)=B
1200 IF X(K)>WIDTH-B-S THEN X(K)=WIDTH-B-S
1210 IF Y(K)<BT THEN Y(K)=BT
1215 IF Y(K)>HEIGHT-B-S THEN Y(K)=HEIGHT-B-S
1218 RETURN
1220 REM Build numbered sprites programmatically
1230 SMALLFONT
1240 FOR I=1 TO NS
1250   CLG : INK 2+((I-1)*5 MOD 28) : FCIRCLE 40,40,R
1260   L$=CHR$(32+I)
1270   MOVE 40-4*LEN(L$),46 : GDISP L$,0,-1
1280   S$(I)=SPRITE$(40-R,40-R,40+R,40+R)
1290 NEXT I
1300 RETURN
