10 DEF FNX(X)=(COS(SIN(SIN(SIN(X)+3*EXP(COS(X)))+3*EXP(COS(SIN(X)+3*EXP(COS(X)))))+3*EXP(COS(SIN(SIN(X)+3*EXP(COS(X)))+3*EXP(COS(SIN(X)+3*EXP(COS(X)))))))-3*SIN(SIN(SIN(SIN(X)+3*EXP(COS(X)))+3*EXP(COS(SIN(X)+3*EXP(COS(X)))))+3*EXP(COS(SIN(SIN(X)+3*EXP(COS(X)))+3*EXP(COS(SIN(X)+3*EXP(COS(X)))))))*EXP(COS(SIN(SIN(SIN(X)+3*EXP(COS(X)))+3*EXP(COS(SIN(X)+3*EXP(COS(X)))))+3*EXP(COS(SIN(SIN(X)+3*EXP(COS(X)))+3*EXP(COS(SIN(X)+3*EXP(COS(X)))))))))*(COS(SIN(SIN(X)+3*EXP(COS(X)))+3*EXP(COS(SIN(X)+3*EXP(COS(X)))))-3*SIN(SIN(SIN(X)+3*EXP(COS(X)))+3*EXP(COS(SIN(X)+3*EXP(COS(X)))))*EXP(COS(SIN(SIN(X)+3*EXP(COS(X)))+3*EXP(COS(SIN(X)+3*EXP(COS(X)))))))*(COS(SIN(X)+3*EXP(COS(X)))-3*SIN(SIN(X)+3*EXP(COS(X)))*EXP(COS(SIN(X)+3*EXP(COS(X)))))*(COS(X)-3*SIN(X)*EXP(COS(X)))
15 MODE 1024
20 B=10 'Border discarded at each end so the labels fit
80 SCREEN : CLG
90 SCALE -1,1,-400,650,B
110 PENWIDTH 2 : INK 5 : MASK &X10000001
120 GRAPH FNX(X),0.01
121 INK 1 : CROSSAT -0.3,0 : YAXIS 0 : CROSSAT 0.4,0 : YAXIS 0
160 PENWIDTH 4 : INK 2 : MASK
170 GRAPHRANGE -0.3,0.4,-100,100
180 GRAPH FNX(X),0.01
