10 W=WIDTH : H=HEIGHT
20 K0=0
30 SCREEN 'ORIGIN 0,0,320-100,320+100,240+100,240-100
40 X1=W/2 : Y1=H/2
50 R1=R2=F9=0
60 T1=TIME
70 V1=24E-3 : V2=32E-3
80 DIM T1(8),T2(8)
90 DIM P1(8),P2(8),P3(8)
100 DIM F(6,4)
110 FOR I=1 TO 8 : READ J : P1(I)=J : NEXT I
120 FOR I=1 TO 8 : READ J : P2(I)=J : NEXT I
130 FOR I=1 TO 8 : READ J : P3(I)=J : NEXT I
140 FOR I=1 TO 6
150 FOR J=1 TO 4
160 READ L
170 F(I,J)=L
180 NEXT J
190 NEXT I
200 FRAME : CLG
210 F9 = F9 + 1
220 R1=R1+V1 : R2=R2+V2
230 S1=SIN(R1) : S2=SIN(R2)
240 C1=COS(R1) : C2=COS(R2)
250 FOR I=1 TO 8
260 Y=P2(I)*C1-P3(I)*S1
270 Z=P3(I)*C1+P2(I)*S1
280 X=P1(I)*C2-Z*S2
290 Z=Z*C2+P1(I)*S2-4
300 T1(I)=INT(X*H/Z+X1)
310 T2(I)=INT(Y*H/Z+Y1)
320 NEXT I
330 FOR I=1 TO 6
340 U1=T1(F(I,1)) : U2=T2(F(I,1))
350 U3=T1(F(I,2)) : U4=T2(F(I,2))
360 U5=T1(F(I,3)) : U6=T2(F(I,3))
370 U7=T1(F(I,4)) : U8=T2(F(I,4))
380 Q1=U1-U7 : Q2=U2-U8 : Q3=U1-U3 : Q4=U2-U4
390 Q0=Q1*Q4-Q2*Q3
400 IF Q0<=0 THEN GOTO 450
410 FTRIANGLE U1,U2,U3,U4,U5,U6,I+1
420 FTRIANGLE U5,U6,U7,U8,U1,U2,I+1
440 IF TIME-T1 > 10 THEN PRINT "FPS:"+STR$(F9/10) : F9=0: T1 = TIME
450 NEXT I
460 GOTO 200
470 DATA -1, 1, 1, -1, -1, 1, 1, -1
480 DATA 1, 1, -1, -1, 1, 1, -1, -1
490 DATA 1, 1, 1, 1, -1, -1, -1, -1
500 DATA 1, 2, 3, 4
510 DATA 5, 6, 2, 1
520 DATA 8, 7, 6, 5
530 DATA 4, 3, 7, 8
540 DATA 2, 6, 7, 3
550 DATA 5, 1, 4, 8

