1000 SCREEN : MODE 640 : PAPER 0 : CLG : BIGFONT
1010 RANDOMIZE TIME : T1=TIME
1020 B=16 : BT=44 : GAPTOP=56 : ROWS=6 : COLS=10 : BW=56 : BH=18 : GX=4 : GY=6
1030 TOPROW=HEIGHT-BT-GAPTOP : MAXB=ROWS*COLS
1040 PW=96 : PH=14 : BR=6 : BS=2*BR+1 : WCOL=RGB(17,5,47) : UICOL=27
1050 DIM BA(MAXB),BXA(MAXB),BYA(MAXB),BBG$(MAXB),BRICK$(4)
1060 SCORE=0 : LIVES=3 : LEFTB=MAXB : STATE=0 : PID=9001 : BID=9002
1070 PX=WIDTH\2-PW\2 : PY=B+12
1080 BX=PX+PW\2-BR : BY=PY+PH+4 : DX=3 : DY=3
1090 GOSUB 1590
1100 GOSUB 1840
1110 GOSUB 2170
1120 GOSUB 2350
1130 PBG$=SPRITE$(PX,PY,PX+PW-1,PY+PH-1)
1140 BBALL$=SPRITE$(BX,BY,BX+BS-1,BY+BS-1)
1150 COLMODE 2
1160 SPRITE PALA$,PX,PY,0,PID
1170 SPRITE BOLA$,BX,BY,0,BID
1180 COLMODE 0
1185 ON MOUSE RIGHTUP GOSUB 2960
1190 FRAME
1195 GOSUB 2865
1200 MOUSE 0
1205 KSTEP=10 : MXLAST=MOUSEX-PW\2
1230 REM ===== Main didactic loop: dirty redraw + COLOR/SPRITE collision =====
1250 REM 1) Restore only the previous background of the paddle and ball (no CLG per frame)
1260 OLDPX=PX : OLDBX=BX : OLDBY=BY
1270 SPRITE PBG$,OLDPX,PY
1280 SPRITE BBALL$,OLDBX,OLDBY
1290 REM 2) Paddle via mouse + KEYDOWN (arrows/A-D)
1295 TX=PX
1300 MX=MOUSEX-PW\2
1301 IF MX<>MXLAST THEN TX=MX : MXLAST=MX
1302 KDIR=0
1304 IF KEYDOWN(28) OR KEYDOWN(65) OR KEYDOWN(97) THEN KDIR=KDIR-1
1306 IF KEYDOWN(29) OR KEYDOWN(68) OR KEYDOWN(100) THEN KDIR=KDIR+1
1308 IF KDIR<>0 THEN TX=TX+SGN(KDIR)*KSTEP
1310 IF TX<B THEN TX=B
1320 IF TX>WIDTH-B-PW THEN TX=WIDTH-B-PW
1330 PX=TX
1340 REM 3) CASE C: ball vs borders by COLOR (COLMODE 1 engine + COLCOLOR WCOL)
1345 REM Didactic note: here we use the engine on purpose to show color collision,
1346 REM but manual detection (IF BX<B ... IF BY>...) would be easier and faster, since
1347 REM the borders are simple straight lines. The engine pays off when you want to detect
1348 REM collisions with color-drawn obstacles and complex shapes.
1350 COLMODE 1 : COLCOLOR WCOL
1355 REM X and Y are tested separately (two HITTESTs) to know WHICH axis bounces.
1356 REM This avoids ambiguous corner bounces and reduces "sticking".
1360 OLDX=BX : BX=BX+DX
1365 SPRITE HITTEST BOLA$,BX,BY,0,BID
1370 IF HITCOLOR<>0 THEN BX=OLDX : DX=-DX
1390 OLDY=BY : BY=BY+DY
1395 SPRITE HITTEST BOLA$,BX,BY,0,BID
1400 IF HITCOLOR<>0 THEN BY=OLDY : DY=-DY
1405 COLMODE 0
1410 IF BY<-BS THEN GOSUB 2670
1420 IF STATE<>0 THEN GOTO 2890
1430 REM 4) CASES A/B: ball vs sprites (A=ball-paddle, B=ball-brick)
1435 REM Here it does simplify things: a single HITTEST returns HITID (paddle or brick)
1440 TPBG$=SPRITE$(PX,PY,PX+PW-1,PY+PH-1)
1450 COLMODE 0 : SPRITE MOVE PID,PX,PY,0
1460 REM In COLMODE 2, HITID returns PID (paddle) or brick id (1..MAXB)
1470 COLMODE 2 : HCOL=0 : SPRITE HITTEST BOLA$,BX,BY,0,BID : IF HITSPRITE THEN HCOL=HITID
1480 COLMODE 0
1490 IF HCOL<>0 THEN GOSUB 2480
1500 IF STATE<>0 THEN GOTO 2890
1510 TBB$=SPRITE$(BX,BY,BX+BS-1,BY+BS-1)
1520 SPRITE MOVE BID,BX,BY,0
1530 PBG$=TPBG$
1540 BBALL$=TBB$
1550 F9=F9+1 : IF TIME-T1>1 THEN SMALLFONT:LOCATE 73,0:DISP "FPS:"+STR$(F9),1,WCOL:BIGFONT:F9=0:T1=TIME
1560 FRAME
1570 PAUSE 8
1580 GOTO 1230
1590 REM ===== Sprite construction (color 0 transparency) =====
1600 CLG
1610 INK 21 : FRECTANGLE 20,20,20+PW-1,20+PH-1
1620 INK 1 : RECTANGLE 20,20,20+PW-1,20+PH-1
1630 INK 16 : FRECTANGLE 24,20+PH-4,20+PW-5,20+PH-2
1640 PALA$=SPRITE$(20,20,20+PW-1,20+PH-1)
1650 CLG
1660 INK 5 : FCIRCLE 40,40,BR
1670 INK 1 : CIRCLE 40,40,BR
1680 INK 15 : FCIRCLE 38,42,2
1690 BOLA$=SPRITE$(40-BR,40-BR,40+BR,40+BR)
1700 FOR K=1 TO 4
1710 CLG
1720 GOSUB 1790
1730 INK BC : FRECTANGLE 10,10,10+BW-1,10+BH-1
1740 INK 1 : RECTANGLE 10,10,10+BW-1,10+BH-1
1750 INK HC : FRECTANGLE 12,10+BH-5,10+BW-3,10+BH-3
1760 BRICK$(K)=SPRITE$(10,10,10+BW-1,10+BH-1)
1770 NEXT K
1780 RETURN
1790 IF K=1 THEN BC=2 : HC=24 : RETURN
1800 IF K=2 THEN BC=8 : HC=23 : RETURN
1810 IF K=3 THEN BC=6 : HC=16 : RETURN
1820 BC=18 : HC=5
1830 RETURN
1840 REM ===== Fixed game background (not cleared every frame) =====
1850 CLG
1860 TW=40 : TH=32
1870 FOR TY=0 TO HEIGHT-1 STEP TH
1880 FOR TX=0 TO WIDTH-1 STEP TW
1890 X2=MIN(TX+TW-1,WIDTH-1) : Y2=MIN(TY+TH-1,HEIGHT-1)
1900 C1=RGB(62,62,68) : C2=RGB(80,80,86)
1910 IF ((TX\TW+TY\TH) MOD 2)=0 THEN C1=RGB(56,56,62) : C2=RGB(74,74,80)
1920 INK C1 : FRECTANGLE TX,TY,X2,Y2
1930 INK C2 : DRAW TX,TY,X2,TY : DRAW TX,TY,TX,Y2
1940 INK RGB(42,42,48) : DRAW TX,Y2,X2,Y2 : DRAW X2,TY,X2,Y2
1950 IF X2-TX>10 AND Y2-TY>10 THEN GOSUB 2050
1960 NEXT TX
1970 NEXT TY
1980 REM WCOL is used only for bouncing: it is not used in UI/background to avoid false positives
1990 INK WCOL : FRECTANGLE 0,0,B-1,HEIGHT-1
2000 INK WCOL : FRECTANGLE WIDTH-B,0,WIDTH-1,HEIGHT-1
2010 INK WCOL : FRECTANGLE 0,HEIGHT-BT,WIDTH-1,HEIGHT-1
2030 MOVE WIDTH\2-16*12\2,HEIGHT-7 : GDISP "AVL ARKANOID",2,WCOL
2040 RETURN
2050 REM Screws at the 4 corners of each tile
2060 S1X=TX+4 : S1Y=TY+4 : S2X=X2-4 : S2Y=Y2-4
2070 SX=S1X : SY=S1Y : GOSUB 2120
2080 SX=S2X : SY=S1Y : GOSUB 2120
2090 SX=S1X : SY=S2Y : GOSUB 2120
2100 SX=S2X : SY=S2Y : GOSUB 2120
2110 RETURN
2120 REM Draw a metallic screw with a horizontal slot
2130 INK RGB(84,84,90) : FCIRCLE SX,SY,2
2140 INK RGB(68,68,74) : PLOT SX-1,SY : PLOT SX,SY : PLOT SX+1,SY
2150 REM Highlight removed for a subtler screw
2160 RETURN
2170 REM ===== Draw bricks + sprite-sprite collision map =====
2180 REM Each brick uses id=N; HITID returns N in ball-brick collision (CASE B)
2190 COLRESET : COLMODE 2
2200 X0=(WIDTH-(COLS*BW+(COLS-1)*GX))\2
2210 N=0
2220 FOR R=1 TO ROWS
2230 Y=TOPROW-(R-1)*(BH+GY)
2240 T=1+((R-1) MOD 4)
2250 FOR C=1 TO COLS
2260 X=X0+(C-1)*(BW+GX)
2270 N=N+1
2280 BA(N)=1 : BXA(N)=X : BYA(N)=Y
2290 BBG$(N)=SPRITE$(X,Y,X+BW-1,Y+BH-1)
2300 SPRITE BRICK$(T),X,Y,0,N
2310 NEXT C
2320 NEXT R
2330 COLMODE 0
2340 RETURN
2350 MOVE WIDTH\2-32*8,HEIGHT-27
2360 GDISP "Points:"+DEC$(SCORE,"0000")+"   Lives:"+DEC$(LIVES,"0")+"   Tiles:"+DEC$(LEFTB,"00")+"  ",1,WCOL
2370 RETURN
2380 REM ===== CASE A: ball-paddle bounce (HCOL=PID via HITTEST in COLMODE 2) =====
2390 IF DY>=0 THEN RETURN
2400 BY=PY+PH : DY=ABS(DY)
2410 POFF=(BX+BR)-(PX+PW\2)
2420 DX=POFF\8
2430 IF DX=0 THEN DX=SGN(POFF)
2440 IF DX=0 THEN DX=1
2450 IF DX>5 THEN DX=5
2460 IF DX<-5 THEN DX=-5
2470 RETURN
2480 REM ===== Dispatch sprite-sprite collision: CASE A (paddle) / CASE B (brick) =====
2490 REM HCOL comes from HITID after HITTEST (COLMODE 2)
2495 REM PID -> paddle ; 1..MAXB -> brick
2500 IF HCOL=PID THEN GOSUB 2380 : RETURN
2510 IF HCOL<1 OR HCOL>MAXB THEN RETURN
2520 IF BA(HCOL)=0 THEN RETURN
2530 BA(HCOL)=0 : LEFTB=LEFTB-1 : SCORE=SCORE+10
2540 SPRITE BBG$(HCOL),BXA(HCOL),BYA(HCOL)
2550 REM Remove the brick from the internal map so it cannot collide again
2560 SPRITE DEL HCOL
2570 OX1=BX+BS-BXA(HCOL)
2580 OX2=BXA(HCOL)+BW-BX
2590 OY1=BY+BS-BYA(HCOL)
2600 OY2=BYA(HCOL)+BH-BY
2610 MX=MIN(OX1,OX2)
2620 MY=MIN(OY1,OY2)
2630 IF MX<MY THEN DX=-DX ELSE DY=-DY
2640 GOSUB 2350
2650 IF LEFTB=0 THEN STATE=1
2660 RETURN
2670 REM ===== Ball lost =====
2680 LIVES=LIVES-1
2690 GOSUB 2770
2700 IF LIVES<=0 THEN STATE=2 : RETURN
2710 BX=PX+PW\2-BR
2720 BY=PY+PH+4
2730 DY=ABS(DY)
2740 DX=SGN(RND-0.5)*3
2750 IF DX=0 THEN DX=3
2760 RETURN
2770 REM ===== Redraw fixed scene + brick collision map (without flashing) =====
2775 REM Note: COLRESET clears sprite owners; that is why the bricks are recreated WITH their id
2780 GOSUB 1840
2790 COLRESET : COLMODE 0
2800 FOR N=1 TO MAXB
2810 IF BA(N)=0 THEN GOTO 2840
2820 R=((N-1)\COLS)+1 : T=1+((R-1) MOD 4)
2830 SPRITE BRICK$(T),BXA(N),BYA(N),0,N
2840 NEXT N
2850 GOSUB 2350
2860 RETURN
2865 REM ===== Start screen: click for focus =====
2866 MSG$="CLICK TO START" : UX=WIDTH\2-LEN(MSG$)*16\2 : UY=HEIGHT\2+8
2867 SBG$=SPRITE$(UX,UY-15,UX+LEN(MSG$)*16-1,UY) : MOVE UX,UY : GDISP MSG$,5,-1 : FRAME
2870 IF MOUSELEFT OR MOUSEEVENT$="LEFTDOWN" THEN SPRITE SBG$,UX,UY-15 : FRAME : RETURN
2872 PAUSE 10 : GOTO 2870
2890 BIGFONT
2900 IF STATE=1 THEN MSG$="COMPLETE!" ELSE MSG$="GAME OVER"
2910 MOVE WIDTH\2-9*16\2,HEIGHT\2+8 : GDISP MSG$,5,-1
2920 SMALLFONT
2930 MSG$="Right button to exit":MOVE WIDTH\2-LEN(MSG$)*8\2,HEIGHT\2-20 : GDISP MSG$,1,-1
2940 FRAME
2950 PAUSE
2960 MOUSE 1
2970 SCREEN CLOSE
2980 END

