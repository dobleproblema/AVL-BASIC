100 REM Minimal example of the sprite collision engine
110 REM 1) COLMODE 1 + HITTEST to bounce against the background
120 REM 2) COLMODE 2 + HITSPRITE/HITID to detect sprite-sprite collisions
130 MODE 640 : SCREEN : PAPER 0 : CLG : SMALLFONT
140 R=9 : S=2*R+1 : B=16
150 DIM S$(3),X(3),Y(3),DX(3),DY(3)
160 GOSUB 560
170 X(1)=120 : Y(1)=120 : DX(1)=2 : DY(1)=1
180 X(2)=500 : Y(2)=220 : DX(2)=-2 : DY(2)=2
190 X(3)=500 : Y(3)=140 : DX(3)=-1 : DY(3)=-2
200 MSG$="" : TMSG=0 : BIGFONT
210 GOSUB 520
220 GOTO 230
230 REM Phase 1: bounce against walls AND TRIANGLE by color
240 COLMODE 1 : COLCOLOR 1
250 FOR I=1 TO 3
260   OLDX=X(I) : X(I)=X(I)+DX(I)
270   SPRITE HITTEST S$(I),X(I),Y(I),0,I
280   IF HITCOLOR<>0 THEN X(I)=OLDX : DX(I)=-DX(I)
290   OLDY=Y(I) : Y(I)=Y(I)+DY(I)
300   SPRITE HITTEST S$(I),X(I),Y(I),0,I
310   IF HITCOLOR<>0 THEN Y(I)=OLDY : DY(I)=-DY(I)
320 NEXT I
330 REM Phase 2: drawing AND SPRITE-SPRITE detection with explicit id
340 GOSUB 520
350 COLMODE 2
360 FOR I=1 TO 3
370   SPRITE S$(I),X(I),Y(I),0,I
380   IF HITSPRITE THEN
390     J=HITID
400     IF J>=1 AND J<=3 THEN
410       X(I)=X(I)-DX(I) : Y(I)=Y(I)-DY(I)
420       T=DX(I) : DX(I)=DX(J) : DX(J)=T
430       T=DY(I) : DY(I)=DY(J) : DY(J)=T
440       SPRITE S$(I),X(I),Y(I),0,I
450       MSG$=CHR$(48+J)+" <-> "+CHR$(48+I)
460       TMSG=75
470     ENDIF
480   ENDIF
490 NEXT I
500 IF TMSG>0 THEN MOVE 275,22 : GDISP MSG$,15,-1 : TMSG=TMSG-1
510 FRAME : GOTO 230
520 REM Fixed background for color-based collisions
530 CLG : INK 1 : RECTANGLE B,B+15,WIDTH-1-B,HEIGHT-1-B
540 FTRIANGLE WIDTH\2-100,HEIGHT\2-80,WIDTH\2+100,HEIGHT\2-80,WIDTH\2,HEIGHT\2+80,1
550 RETURN
560 REM Build three numbered sprites
570 CLG : INK 2 : FCIRCLE 40,40,R : MOVE 36,46 : GDISP "1",0,-1
580 S$(1)=SPRITE$(40-R,40-R,40+R,40+R)
590 CLG : INK 12 : FCIRCLE 40,40,R : MOVE 36,46 : GDISP "2",0,-1
600 S$(2)=SPRITE$(40-R,40-R,40+R,40+R)
610 CLG : INK 8 : FCIRCLE 40,40,R : MOVE 36,46 : GDISP "3",0,-1
620 S$(3)=SPRITE$(40-R,40-R,40+R,40+R)
630 RETURN
