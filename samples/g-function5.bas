100 DEF FNX(X)=SIN(X)/X 'The one-variable function we want to plot
110 MODE 1024 : SCREEN : CLG
120 ON ERROR RESUME NEXT
130 B=20 : D=-3*PI : H=3*PI
140 SCALE D,H,-0.5,1.25,B
150 PENWIDTH 1 : INK 3
160 FOR X=D TO H STEP PI/10
170   MOVE X,0 : DRAW X,FNX(X)
180 NEXT X
190 PENWIDTH 2 : INK 2
200 GRAPH FNX(X)
210 INK 1
220 XAXIS PI,D,H,1,1
230 YAXIS 0.5,-0.5,1.25,1
240 END
