1000 REM MACHIN ALGORITHM TO CALCULATE PI (MODERN VERSION, NO GOTO, NO GOSUB)
1010 REM Uses multiline DEF FN/DEF SUB blocks, LOCAL variables, and block IFs.
1020 REM **Helper functions**
1030 DEF FNBLOCKCOUNT(DIGITS,BLOCKSIZE)
1040   FNBLOCKCOUNT=(DIGITS+1)\BLOCKSIZE
1050 FNEND
1060 DEF FNFORMAT$(BLOCKSIZE)
1070   FNFORMAT$="0"+STRING$(BLOCKSIZE-1,"#")+" "
1080 FNEND
1090 REM **Arithmetic routines**
1100 DEF SUB ADDB1B2
1110   LOCAL A,K,D
1120   K=0 : D=0
1130   IF H<=G THEN
1140     FOR A=G TO H STEP -1
1150       D=B1(A)+B2(A)+K
1160       IF D>=F THEN D=D-F:K=1 ELSE K=0
1170       B1(A)=D
1180     NEXT A
1190   ENDIF
1200   IF K<>0 THEN
1210     FOR A=H-1 TO 0 STEP -1
1220       D=B1(A)+K
1230       IF D>=F THEN D=D-F:K=1 ELSE K=0
1240       B1(A)=D
1250       IF K=0 THEN A=0
1260     NEXT A
1270   ENDIF
1280 SUBEND
1290 DEF SUB SUBB2(USEB3)
1300   LOCAL A,K,D
1310   K=0
1320   IF USEB3 THEN
1330     FOR A=G TO 0 STEP -1
1340       D=B3(A)-B2(A)-K
1350       IF D<0 THEN D=D+F:K=1 ELSE K=0
1360       B1(A)=D
1370     NEXT A
1380   ELSE
1390     IF H<=G THEN
1400       FOR A=G TO H STEP -1
1410         D=B1(A)-B2(A)-K
1420         IF D<0 THEN D=D+F:K=1 ELSE K=0
1430         B1(A)=D
1440       NEXT A
1450     ENDIF
1460     IF K<>0 THEN
1470       FOR A=H-1 TO 0 STEP -1
1480         D=B1(A)-K
1490         IF D<0 THEN D=D+F:K=1 ELSE K=0
1500         B1(A)=D
1510         IF K=0 THEN A=0
1520       NEXT A
1530     ENDIF
1540   ENDIF
1550 SUBEND
1560 DEF SUB MULB1(FACTOR,TOB3)
1570   LOCAL A,K,D
1580   K=0
1590   FOR A=G TO 0 STEP -1
1600     IF B1(A) OR K THEN
1610       D=B1(A)*FACTOR+K
1620       IF D>=F THEN K=D\F:D=D MOD F ELSE K=0
1630       IF TOB3 THEN B3(A)=D:B1(A)=0 ELSE B2(A)=D
1640     ENDIF
1650   NEXT A
1660 SUBEND
1670 DEF SUB DIVB4TOB2(DIVISOR)
1680   LOCAL A,R,D,C,O
1690   R=0 : O=H : H=G+1
1700   IF O<J THEN
1710     FOR A=O TO J-1
1720       B2(A)=0
1730     NEXT A
1740   ENDIF
1750   FOR A=J TO G
1760     IF B4(A)=0 AND R=0 THEN
1770       B2(A)=0
1780     ELSE
1790       D=R*F+B4(A)
1800       C=D\DIVISOR
1810       R=D MOD DIVISOR
1820       B2(A)=C
1830       IF C THEN
1840         IF H>G THEN H=A
1850       ENDIF
1860     ENDIF
1870   NEXT A
1880 SUBEND
1890 DEF SUB DIVB4TOB4(DIVISOR)
1900   LOCAL A,R,D,C,O
1910   Z=1 : O=J : J=G+1 : R=0
1920   FOR A=O TO G
1930     IF B4(A) OR R THEN
1940       D=R*F+B4(A)
1950       C=D\DIVISOR
1960       R=D MOD DIVISOR
1970       B4(A)=C
1980       IF C THEN
1990         Z=0
2000         IF J>G THEN J=A
2010       ENDIF
2020     ENDIF
2030   NEXT A
2040 SUBEND
2090 DEF SUB RECIP(DIVISOR)
2100   LOCAL A,R
2110   R=F
2120   J=G+1
2130   FOR A=0 TO G
2140     B4(A)=R\DIVISOR
2150     IF B4(A) THEN
2160       IF J>G THEN J=A
2180     ENDIF
2190     R=(R MOD DIVISOR)*F
2200   NEXT A
2210 SUBEND
2220 DEF SUB ATANINV(DIVISOR)
2230   LOCAL N,Q
2240   N=1 : Q=DIVISOR*DIVISOR
2250   CALL RECIP(DIVISOR)
2260   Z=0
2270   WHILE Z=0
2280     CALL DIVB4TOB2(N)
2290     CALL ADDB1B2
2300     CALL DIVB4TOB4(Q)
2310     N=N+2
2320     IF Z=0 THEN
2330       CALL DIVB4TOB2(N)
2340       CALL SUBB2(0)
2350       CALL DIVB4TOB4(Q)
2360       N=N+2
2370     ENDIF
2380   WEND
2390 SUBEND
2500 REM **Main program**
2510 P=1000 'INPUT "DIGITS: ",P
2520 L=9 'Safe 9-digit blocks: keeps R*F+B4(A) exact (no rounding) up to 1,000,000 decimal digits
2530 F=10^L : G=FNBLOCKCOUNT(P,L) : F$=FNFORMAT$(L)
2540 DIM B1(G),B2(G),B3(G),B4(G)
2550 T1=TIME
2560 CALL ATANINV(5)
2570 CALL MULB1(16,1)
2580 CALL ATANINV(239)
2590 CALL MULB1(4,0)
2600 CALL SUBB2(1)
2610 T2=TIME
2620 REM Print
2630 FOR A=0 TO G
2640   PRINT USING F$;B1(A);
2650   IF A>0 AND A MOD 8 = 7 THEN PRINT
2660 NEXT A
2670 PRINT : PRINT USING "#.###";T2-T1;" SEG."
2680 END
