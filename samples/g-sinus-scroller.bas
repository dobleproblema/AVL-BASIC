100 REM Sine scroller: one SPRITE column per source pixel
110 SCREEN : MODE 640 : DEG : PAPER 0 : CLG : BIGFONT
120 GS=4 : CW=16*GS+10 : GH=16*GS+8
130 OX=16 : OY=94 : BAS=HEIGHT\2-GH\2 : AMP=70
140 SCROLL=0 : SCROLLSPEED=4 : WPH=0 : WAVESPEED=8 : WAVE=0.45 : DRIFT=4
150 RES=4 'Horizontal scroller resolution: 1=pixel perfect, 2/3/... faster
160 MSG$="      AVL-BASIC PRESENTS A TRUE PIXEL-RESOLUTION SINUS SCROLLER - NO EXTERNAL FONT ASSETS - JUST SPRITE$, TEST AND A LOT OF NOSTALGIA..."
170 CHARS$=" ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789-.,$"
180 N=LEN(MSG$) : TW=N*CW
190 DIM GC$(LEN(CHARS$)*CW-1),MAP(TW+WIDTH+RES-1)
200 REM Building pixel columns
210 GOSUB 600 : SMALLFONT
220 FCOUNT=0 : TLAST=TIME : FPS=0
300 REM Main loop: one vertical text column EVERY RES SCREEN pixels
310 CLG
320 GOSUB 500
330 FOR X=0 TO WIDTH-1 STEP RES
351   M=MAP(SCROLL+X) : IF M>=0 THEN Y=BAS+AMP*SIN(X*WAVE+WPH):SPRITE GC$(M),X,Y,0
360 NEXT X
370 LOCATE 1,1 : DISP "AVL-BASIC SINUS-SCROLLER  FPS: "+DEC$(FPS,".0")+"  ESC=EXIT",18,-1
380 FCOUNT=FCOUNT+1
390 IF TIME-TLAST>=0.5 THEN FPS=FCOUNT/(TIME-TLAST):FCOUNT=0:TLAST=TIME
400 SCROLL=SCROLL+SCROLLSPEED : IF SCROLL>=TW THEN SCROLL=SCROLL-TW
405 WPH=WPH+WAVESPEED : IF WPH>=360 THEN WPH=WPH-360
410 FRAME 60
420 IF KEYDOWN(27) THEN SCREEN CLOSE:END
430 GOTO 300
500 REM Copper-ish background, kept cheap so the columns remain the star
510 FOR B=0 TO 9
520   BY=BAS-74+B*20+7*SIN(WPH+B*23)
530   C=28+B*15
540   FRECTANGLE 0,BY,WIDTH-1,BY+5,RGB(0,C,92+C)
550 NEXT B
560 RETURN
600 REM Render each unique glyph, expand it, and capture every pixel column
610 FOR GI=1 TO LEN(CHARS$)
620   C$=MID$(CHARS$,GI,1)
630   CLG
640   IF C$<>" " THEN MOVE 0,15:GDISP C$,1,-1:GOSUB 800
650   FOR XX=0 TO CW-1
660     K=(GI-1)*CW+XX
670     IF C$<>" " AND XX<16*GS+2 THEN GC$(K)=SPRITE$(OX+XX,OY,OX+XX+RES-1,OY+GH-1)
680   NEXT XX
690 NEXT GI
700 REM Build the scrolling strip as indexes into the glyph-column table
710 FOR I=1 TO N
720   C$=MID$(MSG$,I,1) : P=INSTR(CHARS$,C$) : IF P=0 THEN P=1
730   FOR XX=0 TO CW-1
740     K=(I-1)*CW+XX
750     IF P=1 OR XX>=16*GS+2 THEN MAP(K)=-1 ELSE MAP(K)=(P-1)*CW+XX
760   NEXT XX
770 NEXT I
780 FOR I=0 TO WIDTH+RES-1 : MAP(TW+I)=MAP(I) : NEXT I
790 RETURN
800 REM Expand the built-in 16x16 glyph into a shaded bitmap font
810 FOR SY=0 TO 15
820   FOR SX=0 TO 15
830     IF TEST(SX,SY)=0 THEN GOTO 910
840     DX=OX+SX*GS : DY=OY+4+SY*GS
850     FRECTANGLE DX+2,DY-2,DX+GS+1,DY+GS-3,RGB(0,10,54)
860     FRECTANGLE DX+1,DY-1,DX+GS,DY+GS-2,RGB(146,28,190)
870     FRECTANGLE DX,DY,DX+GS-1,DY+GS-1,RGB(255,192,32)
880     IF SY>7 THEN FRECTANGLE DX,DY,DX+GS-1,DY+GS-1,RGB(255,236,92)
890     IF SY>11 THEN FRECTANGLE DX,DY,DX+GS-1,DY+GS-1,RGB(255,255,210)
900     IF SX=0 OR SY=0 THEN PLOT DX,DY,RGB(255,255,255)
910   NEXT SX
920 NEXT SY
930 RETURN
