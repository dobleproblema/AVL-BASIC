100 REM Amiga-style sine scroller: one sprite column per source pixel
110 SCREEN : MODE 640 : DEG : PAPER 0 : CLG : BIGFONT
120 GS=4 : CW=16*GS+10 : GH=16*GS+8
130 OX=16 : OY=94 : BAS=HEIGHT\2-GH\2 : AMP=70
140 SCROLL=0 : SCROLLSPEED=4 : WPH=0 : WAVESPEED=8 : WAVE=0.45 : DRIFT=4 'SS=3, WS=5
150 MSG$="   AVL-BASIC RUST PRESENTS A TRUE PIXEL-RESOLUTION SINUS SCROLLER - NO EXTERNAL FONT ASSETS - JUST SPRITE$, TEST AND A LOT OF NOSTALGIA...   "
160 CHARS$=" ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789-.,$"
170 N=LEN(MSG$) : TW=N*CW
180 DIM GC$(LEN(CHARS$)*CW-1),MAP(TW-1)
190 SMALLFONT : LOCATE 1,1 : DISP "BUILDING PIXEL COLUMNS...",18,-1 : BIGFONT
200 GOSUB 1000
210 FCOUNT=0 : TLAST=TIME : FPS=0
220 CLG
300 REM Main loop: one vertical text column for every screen pixel
310 CLG
320 GOSUB 800
330 FOR X=0 TO WIDTH-1
340   S=SCROLL+X : IF S>=TW THEN S=S-TW
351   M=MAP(S) : IF M>=0 THEN Y=BAS+AMP*SIN(X*WAVE+WPH):SPRITE GC$(M),X,Y,0
360 NEXT X
370 SMALLFONT : LOCATE 1,1 : DISP "AVL-BASIC SINUS-SCROLLER  FPS: "+DEC$(FPS,".0")+"  ESC=EXIT",18,-1 : BIGFONT
380 FCOUNT=FCOUNT+1
390 IF TIME-TLAST>=0.5 THEN FPS=FCOUNT/(TIME-TLAST):FCOUNT=0:TLAST=TIME
400 SCROLL=SCROLL+SCROLLSPEED : IF SCROLL>=TW THEN SCROLL=SCROLL-TW
405 WPH=WPH+WAVESPEED : IF WPH>=360 THEN WPH=WPH-360
410 FRAME 60
420 IF KEYDOWN(27) THEN SCREEN CLOSE:END
430 GOTO 300
800 REM Copper-ish background, kept cheap so the columns remain the star
810 FOR B=0 TO 9
820   BY=BAS-74+B*20+7*SIN(WPH+B*23)
830   C=28+B*15
840   FRECTANGLE 0,BY,WIDTH-1,BY+5,RGB(0,C,92+C)
850 NEXT B
860 RETURN
1000 REM Render each unique glyph, expand it, and capture every pixel column
1010 FOR GI=1 TO LEN(CHARS$)
1020   C$=MID$(CHARS$,GI,1)
1030   CLG
1040   IF C$<>" " THEN MOVE 0,15:GDISP C$,1,-1:GOSUB 1200
1050   FOR XX=0 TO CW-1
1060     K=(GI-1)*CW+XX
1070     IF C$<>" " AND XX<16*GS+2 THEN GC$(K)=SPRITE$(OX+XX,OY,OX+XX,OY+GH-1)
1090   NEXT XX
1100 NEXT GI
1110 REM Build the scrolling strip as indexes into the glyph-column table
1120 FOR I=1 TO N
1130   C$=MID$(MSG$,I,1) : P=INSTR(CHARS$,C$) : IF P=0 THEN P=1
1140   FOR XX=0 TO CW-1
1150     K=(I-1)*CW+XX
1160     IF P=1 OR XX>=16*GS+2 THEN MAP(K)=-1 ELSE MAP(K)=(P-1)*CW+XX
1170   NEXT XX
1180 NEXT I
1190 RETURN
1200 REM Expand the built-in 16x16 glyph into a shaded bitmap font
1210 FOR SY=0 TO 15
1220   FOR SX=0 TO 15
1230     IF TEST(SX,SY)=0 THEN GOTO 1310
1240     DX=OX+SX*GS : DY=OY+4+SY*GS
1250     FRECTANGLE DX+2,DY-2,DX+GS+1,DY+GS-3,RGB(0,10,54)
1260     FRECTANGLE DX+1,DY-1,DX+GS,DY+GS-2,RGB(146,28,190)
1270     FRECTANGLE DX,DY,DX+GS-1,DY+GS-1,RGB(255,192,32)
1280     IF SY>7 THEN FRECTANGLE DX,DY,DX+GS-1,DY+GS-1,RGB(255,236,92)
1290     IF SY>11 THEN FRECTANGLE DX,DY,DX+GS-1,DY+GS-1,RGB(255,255,210)
1300     IF SX=0 OR SY=0 THEN PLOT DX,DY,RGB(255,255,255)
1310   NEXT SX
1320 NEXT SY
1330 RETURN
