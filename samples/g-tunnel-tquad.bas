1000 REM ============================================================
1010 REM  TEXTURED TUNNEL MESH - AVL BASIC
1020 REM  uses TQUAD instead of per-pixel BASIC texture mapping
1030 REM ============================================================
1040 TEXFILE$="assets/tunnel.png"
1050 W=640 : H=480
1060 SCREEN : MODE 640
1070 PAPER 0 : CLG
1080 DEG
1090 BLOAD TEXFILE$,TEX$
1100 P1=INSTR(TEX$,"x") : P2=INSTR(TEX$,":")
1110 IF P1=0 OR P2=0 THEN PRINT "Formato grafico no valido":END
1120 TW=VAL(LEFT$(TEX$,P1-1))
1130 TH=VAL(MID$(TEX$,P1+1,P2-P1-1))
1140 CX=(W-1)/2 : CY=(H-1)/2
1150 SN=48 : RN=22
1160 HOLE=42 : OUT=430
1170 UREP=6 : VREP=7
1180 DIM X(RN,SN),Y(RN,SN),U(SN),V(RN)
1190 REM PRECALCULATE RING GEOMETRY AND BASE TEXTURE COORDS
1200 FOR A=0 TO SN
1210   U(A)=TW*UREP*A/SN
1220 NEXT A
1230 FOR R=0 TO RN
1240   Q=R/RN
1250   RR=HOLE*(OUT/HOLE)^Q
1260   V(R)=TH*VREP*Q
1270   FOR A=0 TO SN-1
1280     ANG=360*A/SN
1290     X(R,A)=CX+RR*COS(ANG)
1300     Y(R,A)=CY+RR*SIN(ANG)
1310   NEXT A
1315   X(R,SN)=X(R,0)
1317   Y(R,SN)=Y(R,0)
1320 NEXT R
1330 T0=TIME
1340 FCOUNT=0 : TLAST=TIME : FPS=0
1350 REM MAIN LOOP
1360 T=TIME-T0
1370 UO=TW*0.55*T
1380 VO=TH*2.4*T
1390 CLG OFFSCREEN
1400 FOR R=RN-1 TO 0 STEP -1
1410   FOR A=0 TO SN-1
1420     TQUAD TEX$,X(R,A),Y(R,A),U(A)+UO,V(R)+VO,X(R,A+1),Y(R,A+1),U(A+1)+UO,V(R)+VO,X(R+1,A+1),Y(R+1,A+1),U(A+1)+UO,V(R+1)+VO,X(R+1,A),Y(R+1,A),U(A)+UO,V(R+1)+VO
1430   NEXT A
1440 NEXT R
1450 FCIRCLE CX,CY,HOLE,0
1460 FCOUNT=FCOUNT+1
1470 IF TIME-TLAST>=0.5 THEN FPS=FCOUNT/(TIME-TLAST):FCOUNT=0:TLAST=TIME
1480 SMALLFONT
1490 LOCATE 1,1
1500 DISP "AVL-BASIC TEXTURED TUNNEL  FPS: "+DEC$(FPS,"###.0")+"  ESC=EXIT",18,0
1510 FRAME 60
1520 IF KEYDOWN(27) THEN SCREEN CLOSE:END
1530 GOTO 1360
