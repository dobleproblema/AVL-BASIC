100 REM Chess960 starting-position generator
110 SCREEN : MODE 640 : PAPER RGB$(28,29,34) : CLG : SMALLFONT
120 SQ=80 : BY=200 : DIM PIECE$(7),USED(7)
130 RANDOMIZE TIME
140 BLOAD "assets/bishop.png",BISHOP$
150 BLOAD "assets/knight.png",KNIGHT$
160 BLOAD "assets/queen.png",QUEEN$
170 BLOAD "assets/king.png",KING$
180 BLOAD "assets/rook.png",ROOK$
190 GOSUB 1000
200 GOSUB 2000
210 FRAME 30
220 IF KEYDOWN(27) THEN SCREEN CLOSE:END
230 K$=INKEY$
240 IF K$="" THEN 210
250 A=ASC(K$)
260 IF A=32 OR A=13 OR K$="N" OR K$="n" THEN GOSUB 1000:GOSUB 2000
270 GOTO 210
1000 REM Generate a legal Chess960 back rank
1010 FOR I=0 TO 7 : PIECE$(I)="" : USED(I)=0 : NEXT I
1020 P=2*INT(RND*4) : PIECE$(P)="B" : USED(P)=1
1030 P=1+2*INT(RND*4) : PIECE$(P)="B" : USED(P)=1
1040 GOSUB 1500 : PIECE$(P)="N" : USED(P)=1
1050 GOSUB 1500 : PIECE$(P)="N" : USED(P)=1
1060 GOSUB 1500 : PIECE$(P)="Q" : USED(P)=1
1070 J=0
1080 FOR I=0 TO 7
1090   IF USED(I)=0 THEN J=J+1:GOSUB 1600
1100 NEXT I
1110 POS$=""
1120 FOR I=0 TO 7 : POS$=POS$+PIECE$(I) : NEXT I
1130 RETURN
1500 REM Pick one unused square and return it in P
1510 NFREE=0
1520 FOR I=0 TO 7 : IF USED(I)=0 THEN NFREE=NFREE+1
1530 NEXT I
1540 PICK=INT(RND*NFREE)+1 : NFREE=0
1550 FOR I=0 TO 7
1560   IF USED(I)=0 THEN NFREE=NFREE+1:IF NFREE=PICK THEN P=I:RETURN
1570 NEXT I
1580 P=0 : RETURN
1600 REM Remaining squares, left to right, are rook-king-rook
1610 IF J=1 THEN PIECE$(I)="R":RETURN
1620 IF J=2 THEN PIECE$(I)="K":RETURN
1630 PIECE$(I)="R":RETURN
2000 REM Draw the board and pieces
2010 PAPER RGB$(28,29,34) : CLG OFFSCREEN
2020 MOVE 20,452 : GDISP "CHESS960 STARTING POSITION",RGB(255,240,200),-1
2030 MOVE 20,428 : GDISP "SPACE/ENTER/N: NEW POSITION     ESC: EXIT",RGB(190,210,230),-1
2040 FOR I=0 TO 7
2050   X=I*SQ
2060   IF I MOD 2=0 THEN C=RGB(181,136,99) ELSE C=RGB(240,217,181)
2070   FRECTANGLE X,BY,X+SQ-1,BY+SQ-1,C
2080   RECTANGLE X,BY,X+SQ-1,BY+SQ-1,RGB(35,35,38)
2090 NEXT I
2100 FOR I=0 TO 7
2110   X=I*SQ+(SQ-79)\2 : Y=BY+(SQ-79)\2
2120   IF PIECE$(I)="B" THEN SPRITE BISHOP$,X,Y,0
2130   IF PIECE$(I)="N" THEN SPRITE KNIGHT$,X,Y,0
2140   IF PIECE$(I)="Q" THEN SPRITE QUEEN$,X,Y,0
2150   IF PIECE$(I)="K" THEN SPRITE KING$,X,Y,0
2160   IF PIECE$(I)="R" THEN SPRITE ROOK$,X,Y,0
2170 NEXT I
2180 FOR I=0 TO 7
2190   MOVE I*SQ+35,180 : GDISP CHR$(65+I),RGB(210,210,200),-1
2200 NEXT I
2210 MOVE 20,138 : GDISP "BACK RANK: "+POS$,RGB(255,255,255),-1
2220 MOVE 20,112 : GDISP "BISHOPS ARE ON OPPOSITE COLORS; KING IS BETWEEN BOTH ROOKS.",RGB(210,210,200),-1
2230 FRAME
2240 RETURN
