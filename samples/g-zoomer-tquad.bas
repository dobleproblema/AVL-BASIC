100 REM ============================================================
110 REM  TEXTURED ZOOMER-ROTATOR - AVL BASIC
120 REM  one TQUAD per frame
130 REM ============================================================
140 TEXFILE$="assets/texture.png"
150 W=640 : H=480
160 SCREEN : MODE 640
170 PAPER 0 : CLG
180 DEG
190 BLOAD TEXFILE$,TEX$
200 P1=INSTR(TEX$,"x") : P2=INSTR(TEX$,":")
210 IF P1=0 OR P2=0 THEN PRINT "Formato grafico no valido":END
220 TW=VAL(LEFT$(TEX$,P1-1))
230 TH=VAL(MID$(TEX$,P1+1,P2-P1-1))
240 CX=(W-1)/2 : CY=(H-1)/2
250 T0=TIME
260 FCOUNT=0 : TLAST=TIME : FPS=0
270 REM MAIN LOOP
280 T=TIME-T0
290 A=T*28
300 Z=0.75+1.6*(1+SIN(T*58))^2
310 IZ=1/Z : CA=COS(A) : SA=SIN(A)
320 UOFF=TW*0.45*SIN(T*83)
330 VOFF=TH*0.35*COS(T*71)
340 DX=0-CX : DY=0-CY
350 U0=TW/2+(DX*CA+DY*SA)*IZ+UOFF
360 V0=TH/2+(-DX*SA+DY*CA)*IZ+VOFF
370 DX=W-1-CX : DY=0-CY
380 U1=TW/2+(DX*CA+DY*SA)*IZ+UOFF
390 V1=TH/2+(-DX*SA+DY*CA)*IZ+VOFF
400 DX=W-1-CX : DY=H-1-CY
410 U2=TW/2+(DX*CA+DY*SA)*IZ+UOFF
420 V2=TH/2+(-DX*SA+DY*CA)*IZ+VOFF
430 DX=0-CX : DY=H-1-CY
440 U3=TW/2+(DX*CA+DY*SA)*IZ+UOFF
450 V3=TH/2+(-DX*SA+DY*CA)*IZ+VOFF
460 TQUAD TEX$,0,0,U0,V0,W-1,0,U1,V1,W-1,H-1,U2,V2,0,H-1,U3,V3
470 FCOUNT=FCOUNT+1
480 IF TIME-TLAST>=0.5 THEN FPS=FCOUNT/(TIME-TLAST):FCOUNT=0:TLAST=TIME
490 SMALLFONT
500 LOCATE 1,1
510 DISP "AVL-BASIC TEXTURED ZOOMER  FPS: "+DEC$(FPS,"###.0")+"  ESC=EXIT",18,0
520 FRAME 60
530 IF KEYDOWN(27) THEN SCREEN CLOSE:END
540 GOTO 280
