100 REM ============================================================
110 REM  TEXTURED 3D CUBE - AVL BASIC
120 REM  3D projection + 2D affine textured quads
130 REM ============================================================
140 TEXFILE$="assets/texture.png" 'Try also assets/tunnel.png
150 W=640 : H=480
160 SCREEN : MODE 640
170 PAPER 0 : CLG
180 BLOAD TEXFILE$,TEX$
190 P1=INSTR(TEX$,"x") : P2=INSTR(TEX$,":")
200 IF P1=0 OR P2=0 THEN PRINT "Formato grafico no valido":END
210 TW=VAL(LEFT$(TEX$,P1-1))
220 TH=VAL(MID$(TEX$,P1+1,P2-P1-1))
230 XC=(W-1)/2 : YC=(H-1)/2
240 FOC=430 : DIST=4.2
250 SUBD=6 '1 = one affine TQUAD per face; 6 approximates perspective well
260 DIM PX0(8),PY0(8),PZ0(8)
270 DIM VX(8),VY(8)
280 DIM F(6,4)
290 FOR I=1 TO 8 : READ Q : PX0(I)=Q : NEXT I
300 FOR I=1 TO 8 : READ Q : PY0(I)=Q : NEXT I
310 FOR I=1 TO 8 : READ Q : PZ0(I)=Q : NEXT I
320 FOR I=1 TO 6
330   FOR J=1 TO 4
340     READ Q : F(I,J)=Q
350   NEXT J
360 NEXT I
370 TSTART=TIME
380 FCOUNT=0 : TLAST=TIME : FPS=0
390 REM MAIN LOOP
400 T=TIME-TSTART
410 A=T*0.82 : B=T*1.08 : C=T*0.37
420 SA=SIN(A) : CA=COS(A)
430 SB=SIN(B) : CB=COS(B)
440 SC=SIN(C) : CC=COS(C)
450 CLG OFFSCREEN
460 REM Project the 8 real cube vertices for hidden-face removal
470 FOR I=1 TO 8
480   PX=PX0(I) : PY=PY0(I) : PZ=PZ0(I)
490   GOSUB 2000
500   VX(I)=GX : VY(I)=GY
510 NEXT I
520 FOR FC=1 TO 6
530   IA=F(FC,1) : IB=F(FC,2) : IC=F(FC,3) : ID=F(FC,4)
540   AX2=VX(IA) : AY2=VY(IA)
550   BX2=VX(IB) : BY2=VY(IB)
560   CX2=VX(IC) : CY2=VY(IC)
570   DX2=VX(ID) : DY2=VY(ID)
580   Q1=AX2-DX2 : Q2=AY2-DY2 : Q3=AX2-BX2 : Q4=AY2-BY2
590   IF Q1*Q4-Q2*Q3>=0 THEN GOTO 690
600   AX=PX0(IA) : AY=PY0(IA) : AZ=PZ0(IA)
610   BX=PX0(IB) : BY=PY0(IB) : BZ=PZ0(IB)
620   CX=PX0(IC) : CY=PY0(IC) : CZ=PZ0(IC)
630   DX=PX0(ID) : DY=PY0(ID) : DZ=PZ0(ID)
640   FU=0
650   FV=0
660   GOSUB 1000
670   INK 0
680   DRAW AX2,AY2,BX2,BY2 : DRAW CX2,CY2 : DRAW DX2,DY2 : DRAW AX2,AY2
690 NEXT FC
700 FCOUNT=FCOUNT+1
710 IF TIME-TLAST>=0.5 THEN FPS=FCOUNT/(TIME-TLAST):FCOUNT=0:TLAST=TIME
720 SMALLFONT
730 LOCATE 1,1
740 DISP "AVL-BASIC TEXTURED CUBE  FPS: "+DEC$(FPS,"###.0")+"  SUB="+DEC$(SUBD,"#")+"  ESC=EXIT",18,0
750 FRAME 60
760 IF KEYDOWN(27) THEN SCREEN CLOSE:END
770 GOTO 400
1000 REM Draw current face as SUB*SUB affine textured quads
1010 FOR JJ=0 TO SUBD-1
1020   TV0=JJ/SUBD : TV1=(JJ+1)/SUBD
1030   FOR II=0 TO SUBD-1
1040     TU0=II/SUBD : TU1=(II+1)/SUBD
1050     SS=TU0 : TT=TV0 : GOSUB 3000 : X00=GX : Y00=GY
1060     SS=TU1 : TT=TV0 : GOSUB 3000 : X10=GX : Y10=GY
1070     SS=TU1 : TT=TV1 : GOSUB 3000 : X11=GX : Y11=GY
1080     SS=TU0 : TT=TV1 : GOSUB 3000 : X01=GX : Y01=GY
1090     U0=FU+TW*TU0 : V0=FV+TH*TV0
1100     U1=FU+TW*TU1 : V1=FV+TH*TV1
1110     TQUAD TEX$,X00,Y00,U0,V0,X10,Y10,U1,V0,X11,Y11,U1,V1,X01,Y01,U0,V1
1120   NEXT II
1130 NEXT JJ
1140 RETURN
2000 REM Rotate and project PX,PY,PZ -> GX,GY
2010 RY=PY*CA-PZ*SA
2020 RZ=PZ*CA+PY*SA
2030 RX=PX*CB+RZ*SB
2040 RZ=RZ*CB-PX*SB
2050 X3=RX*CC-RY*SC
2060 Y3=RY*CC+RX*SC
2070 Z3=RZ+DIST
2080 GX=XC+X3*FOC/Z3
2090 GY=YC+Y3*FOC/Z3
2100 RETURN
3000 REM Bilinear point on current face at SS,TT
3010 PX=AX+(BX-AX)*SS+(DX-AX)*TT+(AX-BX+CX-DX)*SS*TT
3020 PY=AY+(BY-AY)*SS+(DY-AY)*TT+(AY-BY+CY-DY)*SS*TT
3030 PZ=AZ+(BZ-AZ)*SS+(DZ-AZ)*TT+(AZ-BZ+CZ-DZ)*SS*TT
3040 GOSUB 2000
3050 RETURN
4000 DATA -1, 1, 1, -1, -1, 1, 1, -1
4010 DATA 1, 1, -1, -1, 1, 1, -1, -1
4020 DATA 1, 1, 1, 1, -1, -1, -1, -1
4030 DATA 1, 2, 3, 4
4040 DATA 5, 6, 2, 1
4050 DATA 8, 7, 6, 5
4060 DATA 4, 3, 7, 8
4070 DATA 2, 6, 7, 3
4080 DATA 5, 1, 4, 8
