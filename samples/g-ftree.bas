100 DEG : SCREEN : CLG
110 MOVE WIDTH\2,HEIGHT\10
120 NM=12 : N=0 : F=1/SQR(2)
130 DIM A(NM),L(NM),X(NM),Y(NM)
140 A(N)=0 : L(N)=HEIGHT\4 : X(N)=XPOS : Y(N)=YPOS
150 GOSUB 170
160 END
170 REM Subroutine that simulates recursion
180 DRAW X(N)+L(N)*SIN(A(N)),Y(N)+L(N)*COS(A(N)) : FRAME
190 N=N+1 : IF N<NM THEN X(N)=XPOS:Y(N)=YPOS ELSE 250
200 A(N)=A(N-1)+45 : L(N)=L(N-1)*F
210 GOSUB 170
220 A(N)=A(N-1)-45
230 MOVE X(N),Y(N)
240 GOSUB 170
250 N=N-1 : MOVE X(N),Y(N)
260 RETURN

