100 REM MACHIN ALGORITHM TO CALCULATE PI (DEF SUB VERSION)
110 REM Rewrite of pimachin.bas using named DEF SUB routines
120 REM **DEF SUB routines**
130 DEF SUB B4ZERO
140   LOCAL A
150   Z=1
160   FOR A=G TO 0 STEP -1
170     IF B4(A) THEN Z=0 : SUBEXIT
180   NEXT A
190 SUBEND
200 DEF SUB ADDB1B2
210   LOCAL A,K,D
220   K=0 : D=0
230   FOR A=G TO 0 STEP -1
240     D=B1(A)+B2(A)+K
250     IF D>F THEN D=D-F:K=1 ELSE K=0
260     B1(A)=D
270   NEXT A
280 SUBEND
290 DEF SUB SUBB2(USEB3)
300   LOCAL A,K,D
310   K=0
320   FOR A=G TO 0 STEP -1
330     IF USEB3 THEN D=B3(A)-B2(A)-K ELSE D=B1(A)-B2(A)-K
340     IF D<0 THEN D=D+F:K=1 ELSE K=0
350     B1(A)=D
360   NEXT A
370 SUBEND
380 DEF SUB MULB1(P,TOB3)
390   LOCAL A,K,D
400   K=0
410   FOR A=G TO 0 STEP -1
420     IF B1(A)=K THEN 460
430     D=B1(A)*P+K
440     IF D>F THEN K=D\F:D=D MOD F ELSE K=0
450     IF TOB3 THEN B3(A)=D:B1(A)=0 ELSE B2(A)=D
460   NEXT A
470 SUBEND
480 DEF SUB DIVB4(P,TOB4)
490   LOCAL A,R,D,C
500   R=0
510   FOR A=0 TO G
520     IF B4(A)=R THEN B2(A)=0 ELSE D=R*F+B4(A):C=D\P:R=D MOD P:IF TOB4 THEN B4(A)=C ELSE B2(A)=C
530   NEXT A
540 SUBEND
550 DEF SUB RECIP(P)
560   LOCAL A,R
570   R=F
580   FOR A=0 TO G
590     B4(A)=R\P
600     R=(R MOD P)*F
610   NEXT A
620 SUBEND
630 DEF SUB ATANINV(P)
640   LOCAL S,N,Q,Z
650   S=1 : N=1 : Q=P*P : Z=0
660   CALL RECIP(P)
670   WHILE Z=0
680     CALL DIVB4(N,0)
690     IF S=1 THEN CALL ADDB1B2 ELSE CALL SUBB2(0)
700     CALL DIVB4(Q,1)
710     N=N+2 : S=3-S
720     CALL B4ZERO
730   WEND
740 SUBEND
750 REM **Main program**
760 P=1000 'INPUT "DIGITS: ",P
770 L=11 : F=10^L : G=(P+1)\L
780 DIM B1(G),B2(G),B3(G),B4(G)
790 T1=TIME
800 CALL ATANINV(5)
810 CALL MULB1(16,1)
820 CALL ATANINV(239)
830 CALL MULB1(4,0)
840 CALL SUBB2(1)
850 T2=TIME
860 REM Print
870 FOR A=0 TO G
880   PRINT USING "0########## ";B1(A);
890   IF A>0 AND A MOD 6 = 5 THEN PRINT
900 NEXT A
910 PRINT : PRINT USING "#.###";T2-T1;" SEG."
920 STOP
