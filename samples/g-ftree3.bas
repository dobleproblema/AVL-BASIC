100 DEF FNLW(X)=MAX(1,4\(2^(X\2)))
110 DEF FNR$(N)=STR$(RM0+(RM1-RM0)*MIN(N,NM/2)/(NM/2)+(RV0-RM1)*MAX(0,N-NM/2)/(NM/2))
120 DEF FNG$(N)=STR$(GM0+(GM1-GM0)*MIN(N,NM/2)/(NM/2)+(GV0-GM1)*MAX(0,N-NM/2)/(NM/2))
130 DEF FNB$(N)=STR$(BM0+(BM1-BM0)*MIN(N,NM/2)/(NM/2)+(BV0-BM1)*MAX(0,N-NM/2)/(NM/2))
140 DEG : SCREEN : CLG
150 MOVE WIDTH\2,HEIGHT\10
160 NM=13 : N=0 : F=1/SQR(2)
170 RM0=139 : GM0=69 : BM0=19 'Brown
180 RM1=255 : GM1=215 : BM1=0 'Intermediate golden yellow
190 RV0=34 : GV0=255 : BV0=34 'Green
200 DIM A(NM),L(NM),X(NM),Y(NM)
210 A(N)=0 : L(N)=HEIGHT\4 : X(N)=XPOS : Y(N)=YPOS
220 GOSUB 240
230 END
240 REM Subroutine that simulates recursion
250 INK FNR$(N)+","+FNG$(N)+","+FNB$(N)
260 PENWIDTH FNLW(N)
270 DRAW X(N)+L(N)*SIN(A(N)),Y(N)+L(N)*COS(A(N)) : FRAME
280 N=N+1 : IF N<NM THEN X(N)=XPOS:Y(N)=YPOS ELSE 350
290 '25° on the right branch for a more "organic" look
300 A(N)=A(N-1)+25 : L(N)=L(N-1)*F
310 GOSUB 240
320 A(N)=A(N-1)-45
330 MOVE X(N),Y(N)
340 GOSUB 240
350 N=N-1 : MOVE X(N),Y(N)
360 RETURN

