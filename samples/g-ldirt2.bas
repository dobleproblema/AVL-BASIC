10 CLG : BIGFONT : DEG
20 T$="COPYRIGHT 2025 JOSE ANTONIO AVILA - "
30 T1=T2=P1=P2=1 : L=LEN(T$)
40 T0=TIME
50 FOR C=1 TO 200
60 CLG
70 FOR X=T1 TO 360+T1 STEP 10
80 MOVE WIDTH\2+SIN(X)*200,HEIGHT\2+COS(X)*200
90 C$=MID$(T$,P1,1)
100 P1=(P1+1) MOD L
110 LDIR -X : GDISP C$
120 NEXT
130 FOR X=T2 TO 360+T2 STEP 10
140 MOVE WIDTH\2+SIN(X)*100,HEIGHT\2+COS(X)*100
150 C$=MID$(T$,P2,1)
160 P2=(P2+1) MOD L
170 LDIR -X : GDISP C$,1,-1
180 NEXT
190 FRAME : T1=T1+9 : T2=T2+6
200 NEXT C
210 PRINT "Elapsed time:";TIME-T0

