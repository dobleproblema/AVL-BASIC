100 REM Big Bang particle morph between two PNG images
110 MODE 640 : SCREEN : PAPER 0 : CLG : RAD : SMALLFONT
115 REM PART controls quality/speed: 1=Rust detail, 2=Python-friendly
120 IW=100 : IH=100 : ZM=2.2 : PART=1
125 PST=INT(PART) : IF PST<1 THEN PST=1
130 DS=INT(PST*ZM+1) : D1=DS-1
135 DLY=100 : EXPF=240 : IMPF=280 : BLAST=1.35 : VS=1.2*ZM*BLAST : TOT=2*(DLY+EXPF+IMPF)
138 HUD=1
140 OX=(WIDTH-IW*2*ZM)/2 : OY=(HEIGHT-IH*2*ZM)/2
150 MAXP=(IW\PST+1)*(IH\PST+1)
160 DIM SX(MAXP),SY(MAXP),TX(MAXP),TY(MAXP),VX(MAXP),VY(MAXP),C(MAXP)
165 DIM DX(MAXP),DY(MAXP),JX(MAXP),JY(MAXP),EXA(MAXP),EYA(MAXP),EXB(MAXP),EYB(MAXP)
170 RANDOMIZE 1701
180 GOSUB 1000
190 F=1 : FCOUNT=0 : TLAST=TIME : FPS=0 : FPS$=".0"
195 INFO$="AVL-BASIC BIG BANG  PART:"+STR$(PST)+"  PARTICLES:"+STR$(NP)+"  FPS:"
200 CLG OFFSCREEN
210 IF F<=DLY THEN GOSUB 500:GOTO 390
220 IF F<=DLY+EXPF THEN T=F-DLY:GOSUB 540:GOTO 390
230 IF F<=DLY+EXPF+IMPF THEN Q=(F-DLY-EXPF)/IMPF:Q=Q*Q*(3-2*Q):GOSUB 580:GOTO 390
240 IF F<=2*DLY+EXPF+IMPF THEN GOSUB 620:GOTO 390
250 IF F<=2*DLY+2*EXPF+IMPF THEN T=F-(2*DLY+EXPF+IMPF):GOSUB 660:GOTO 390
260 Q=(F-2*DLY-2*EXPF-IMPF)/IMPF : Q=Q*Q*(3-2*Q) : GOSUB 700
390 FCOUNT=FCOUNT+1
400 IF TIME-TLAST>=0.5 THEN FPS=FCOUNT/(TIME-TLAST):FPS$=DEC$(FPS,".0"):FCOUNT=0:TLAST=TIME
410 IF HUD THEN LOCATE 1,1:DISP INFO$+FPS$+"  ESC=EXIT",18,-1
420 FRAME 60
430 IF KEYDOWN(27) THEN SCREEN CLOSE:END
440 F=F+1 : IF F>TOT THEN F=1
450 GOTO 200
500 REM Logo hold
510 FOR I=0 TO N1 : X=SX(I) : Y=SY(I) : FRECTANGLE X,Y,X+D1,Y+D1,C(I) : NEXT I
520 RETURN
540 REM Logo explosion
550 FOR I=0 TO N1 : X=SX(I)+VX(I)*T : Y=SY(I)+VY(I)*T : FRECTANGLE X,Y,X+D1,Y+D1,C(I) : NEXT I
560 RETURN
580 REM Implosion into the target image
590 FOR I=0 TO N1 : X=EXA(I)+DX(I)*Q : Y=EYA(I)+DY(I)*Q : FRECTANGLE X,Y,X+D1,Y+D1,C(I) : NEXT I
600 RETURN
620 REM Target hold
630 FOR I=0 TO N1 : X=TX(I) : Y=TY(I) : FRECTANGLE X,Y,X+D1,Y+D1,C(I) : NEXT I
640 RETURN
660 REM Target explosion
670 FOR I=0 TO N1 : X=TX(I)+VX(I)*T : Y=TY(I)+VY(I)*T : FRECTANGLE X,Y,X+D1,Y+D1,C(I) : NEXT I
680 RETURN
700 REM Implosion back into the logo
710 FOR I=0 TO N1 : X=EXB(I)+JX(I)*Q : Y=EYB(I)+JY(I)*Q : FRECTANGLE X,Y,X+D1,Y+D1,C(I) : NEXT I
720 RETURN
900 REM Store logo particle from PX/PY/PC
910 SX(NP)=OX+(PX+IW/2)*ZM : SY(NP)=OY+(IH-1-PY+IH/2)*ZM : C(NP)=PC
920 A=RND*2*PI : SP=(0.05+RND*0.7)*VS
930 VX(NP)=COS(A)*SP : VY(NP)=SIN(A)*SP
940 NP=NP+1 : RETURN
960 REM Store target particle from PX/PY
970 DX(ND)=OX+(PX+IW/2)*ZM : DY(ND)=OY+(IH-1-PY+IH/2)*ZM : ND=ND+1 : RETURN
1000 REM Load the images and extract particles. Relative paths resolve from this sample.
1010 CLG : BLOAD "assets/bigbang-logo.png",IMG$ : SPRITE IMG$,0,0
1020 NP=0
1030 FOR PY=0 TO IH-1 STEP PST
1040   FOR PX=0 TO IW-1 STEP PST
1050     PC=TEST(PX,IH-1-PY) : IF PC<>0 THEN GOSUB 900
1060   NEXT PX
1070 NEXT PY
1080 CLG : BLOAD "assets/bigbang-peace.png",IMG$ : SPRITE IMG$,0,0
1090 ND=0
1100 FOR PY=0 TO IH-1 STEP PST
1110   FOR PX=0 TO IW-1 STEP PST
1120     PC=TEST(PX,IH-1-PY) : IF PC<>0 THEN GOSUB 960
1130   NEXT PX
1140 NEXT PY
1150 IF ND<1 THEN ND=1:DX(0)=OX+IW*ZM:DY(0)=OY+IH*ZM
1160 FOR I=0 TO NP-1
1170   J=(I*37+17) MOD ND
1180   TX(I)=DX(J) : TY(I)=DY(J)
1190 NEXT I
1200 FOR I=0 TO NP-1
1210   EXA(I)=SX(I)+VX(I)*EXPF : EYA(I)=SY(I)+VY(I)*EXPF
1220   EXB(I)=TX(I)+VX(I)*EXPF : EYB(I)=TY(I)+VY(I)*EXPF
1230   DX(I)=TX(I)-EXA(I) : DY(I)=TY(I)-EYA(I)
1240   JX(I)=SX(I)-EXB(I) : JY(I)=SY(I)-EYB(I)
1250 NEXT I
1260 N1=NP-1
1270 CLG : RETURN
