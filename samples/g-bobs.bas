100 REM Classic Amiga-style bobs: six huge circles in a true 3D orbit
110 MODE 800 : SCREEN : PAPER 27 : SMALLFONT : RAD
120 W=WIDTH : H=HEIGHT : Xc=W/2 : Yc=H/2+25
130 N=6 : DistCam=4.6 : Rorb=2.45 : Vorb=2.8E-2 : Vcam=7E-3 : RB=0.86 : OrbA=0 : CamA=0
140 DIM PX(N),PY(N),PR(N),O(N)
150 FPS=0 : FC=0 : T0=TIME
160 REM Main loop
170 FRAME 60 : CLG OFFSCREEN
180 OrbA=OrbA+Vorb : CamA=CamA+Vcam
190 CamS=SIN(CamA) : CamC=COS(CamA)
200 FOR I=1 TO N
210   A=OrbA+(I-1)*2*PI/N
220   OrbS=SIN(A) : OrbC=COS(A)
230   XW=Rorb*OrbC : YW=Rorb*OrbS*CamS : ZW=DistCam+Rorb*OrbS*CamC
240   PX(I)=INT(Xc+XW*H/ZW) : PY(I)=INT(Yc+YW*H/ZW) : PR(I)=INT(RB*H/ZW) : O(I)=I
250 NEXT I
260 REM Draw farthest bobs first
270 FOR A=1 TO N
280   FOR B=A+1 TO N
290     IF PR(O(A))>PR(O(B)) THEN SWAP O(A),O(B)
300   NEXT B
310   I=O(A) : FCIRCLE PX(I),PY(I),PR(I),I+19
320 NEXT A
330 FC=FC+1 : IF TIME-T0>=0.5 THEN FPS=ROUND(FC/(TIME-T0)):FC=0:T0=TIME
340 DISP "AVL-BASIC SIX ORBITING BOBS  FPS: "+STR$(FPS)+"  ESC=EXIT",14,-1
350 IF KEYDOWN(27) THEN SCREEN CLOSE ELSE 170
