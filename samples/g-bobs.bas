100 REM Classic Amiga-style bobs: six huge circles in a true 3D orbit
110 MODE 800 : SCREEN : PAPER RGB$(30,31,33) : CLG : SMALLFONT
120 W=WIDTH : H=HEIGHT : Xc=W/2 : Yc=H/2+25
130 N=6 : DistCam=5.6 : Rorb=2.45 : Vorb=28E-3
140 RB=0.86 : TiltY=0.42 : OrbA=0
150 DIM PX(N),PY(N),PR(N),PZ(N),CC(N),O(N)
160 FOR I=1 TO N
170   READ CR,CG,CB : CC(I)=RGB(CR,CG,CB) : O(I)=I
180 NEXT I
190 FPS=0 : FC=0 : T0=TIME
200 REM Main loop
210 CLG OFFSCREEN
220 OrbA=OrbA+Vorb
230 FOR I=1 TO N
240   A=OrbA+(I-1)*2*PI/N
250   SN=SIN(A) : CA=COS(A)
260   XW=Rorb*CA : YW=TiltY*SN : ZW=DistCam+Rorb*SN
270   PX(I)=INT(Xc+XW*H/ZW)
280   PY(I)=INT(Yc+YW*H/ZW)
290   PR(I)=INT(RB*H/ZW)
300   PZ(I)=ZW
310   O(I)=I
320 NEXT I
330 REM Draw farthest bobs first, exactly like g-cube2.bas
340 FOR A=1 TO N-1
350   FOR B=A+1 TO N
360     IF PZ(O(A))<PZ(O(B)) THEN K=O(A) : O(A)=O(B) : O(B)=K
370   NEXT B
380 NEXT A
390 FOR K=1 TO N
400   I=O(K)
410   FCIRCLE PX(I),PY(I),PR(I),CC(I)
420 NEXT K
430 FC=FC+1 : IF TIME-T0>=0.5 THEN FPS=FC/(TIME-T0) : FC=0 : T0=TIME
440 DISP "AVL-BASIC SIX ORBITING BOBS  FPS: "+DEC$(FPS,"###.0")+"  ESC=EXIT",14,0
450 FRAME 60
460 IF KEYDOWN(27) THEN SCREEN CLOSE:END
470 GOTO 210
