1000 REM Ray-Tracer
1005 REM Refraction + reflectivity (Fresnel)
1010 REM General parameters
1020 EPS=0.0001
1025 MXD=4 'Maximum depth (lets you see the refracted checkerboard in 2nd-order reflections)
1030 WTH=0.04 'Weight threshold for pruning branches
1035 REM Camera and render
1040 WID=640 : HEI=480
1045 CAMX=0 : CAMY=1 : CAMZ=5
1050 FOVD=60
1055 FOVR=FOVD*PI/180
1060 SC=TAN(FOVR/2)
1065 ASP=WID/HEI
1070 FX=(2*ASP*SC)/WID
1075 FY=(2*SC)/HEI
1080 PX0=-ASP*SC : PY0=-SC
1085 REM Light, ambient and background (contrast + reflections, without darkening the scene)
1090 LX=6.5 : LY=7.5 : LZ=4.5
1095 LCR=1.15 : LCG=1.12 : LCB=1.08
1100 AMB=0.1
1105 BGR=0.58 : BGG=0.68 : BGB=0.9
1110 REM Ground plane (y=0), checkerboard
1115 PLY=0
1120 PLREFL=0.52
1125 PLSPEC=10
1130 TILE=1
1135 TILEI=1/TILE
1140 KSP=8 : KSP2=1.25 'Direct specular highlight strength
1145 REM Spheres
1150 NS=2
1155 REM Glass sphere
1160 SX(0)=-0.55 : SY(0)=1.25 : SZ(0)=1
1165 SR(0)=1.25
1170 CR(0)=1 : CG(0)=1 : CB(0)=1
1175 RF(0)=0.05 : TR(0)=1 : IO(0)=1.5 : SP(0)=20
1180 R0(0)=((IO(0)-1)/(IO(0)+1))^2
1185 REM Green sphere
1190 SX(1)=1.25 : SY(1)=0.75 : SZ(1)=-0.25
1195 SR(1)=0.75
1200 CR(1)=0.1 : CG(1)=0.8 : CB(1)=0.2
1205 RF(1)=0.38 : TR(1)=0 : IO(1)=1 : SP(1)=90
1210 R0(1)=((IO(1)-1)/(IO(1)+1))^2
1215 REM OPT: Precompute sphere values
1220 FOR I=0 TO NS-1
1225   SR2(I)=SR(I)*SR(I)
1230   IF SR(I)<>0 THEN INVSR(I)=1/SR(I)
1235 NEXT I
1240 REM Stack for iterative tracing
1245 DIM ORX(256),ORY(256),ORZ(256)
1250 DIM ODX(256),ODY(256),ODZ(256)
1255 DIM OWR(256),OWG(256),OWB(256)
1260 DIM ODP(256)
1265 REM Intersection variables (global for subroutines)
1270 HTB=0 : HT=0 : HX=0 : HY=0 : HZ=0
1275 NX=0 : NY=0 : NZ=0 : HOBJ=0 : HID=0
1280 REM Timer
1285 T0=TIME
1290 REM Main render loop
1295 MODE 640 : ORIGIN (WIDTH-WID)\2,(HEIGHT-HEI)\2 : CLG
1300 FOR Y=0 TO HEI-1
1305   PY=(Y+0.5)*FY+PY0 'Origin at the lower-left corner
1310   PX=PX0+0.5*FX
1315   FOR X=0 TO WID-1
1320     PZ=-1
1325     RL=SQR(PX*PX+PY*PY+PZ*PZ) : IF RL>0 THEN RDX=PX/RL : RDY=PY/RL : RDZ=PZ/RL ELSE RDX=0 : RDY=0 : RDZ=-1
1330     ROX=CAMX : ROY=CAMY : ROZ=CAMZ
1335     GOSUB 1400 'TRACE -> returns AR,AG,AB
1340     R=INT(255*AR) : R=MAX(0,MIN(255,R))
1345     G=INT(255*AG) : G=MAX(0,MIN(255,G))
1350     B=INT(255*AB) : B=MAX(0,MIN(255,B))
1355     INK R,G,B
1360     PLOT X,Y
1365     PX=PX+FX
1370   NEXT X
1375   IF (Y-32*INT(Y/32))=0 THEN FRAME 'Refresh every 32 lines
1380 NEXT Y
1385 T1=TIME
1390 PRINT "Render finished in";ROUND(T1-T0,2);"sec."
1395 END
1400 REM TRACE SUBROUTINE (stack)
1405 AR=0 : AG=0 : AB=0
1410 ST=0
1415 ST=ST+1
1420 ORX(ST)=ROX : ORY(ST)=ROY : ORZ(ST)=ROZ
1425 ODX(ST)=RDX : ODY(ST)=RDY : ODZ(ST)=RDZ
1430 OWR(ST)=1 : OWG(ST)=1 : OWB(ST)=1
1435 ODP(ST)=MXD
1440 WHILE ST>0
1445   ROX=ORX(ST) : ROY=ORY(ST) : ROZ=ORZ(ST)
1450   RDX=ODX(ST) : RDY=ODY(ST) : RDZ=ODZ(ST)
1455   WR=OWR(ST) : WG=OWG(ST) : WB=OWB(ST)
1460   DP=ODP(ST)
1465   ST=ST-1
1470   IF DP<=0 THEN AR=AR+WR*BGR : AG=AG+WG*BGG : AB=AB+WB*BGB : GOTO 1905
1475   SHAD=0 : GOSUB 1920 ' -> HTB,HT,HX,HY,HZ,NX,NY,NZ,HOBJ,HID
1480   IF HTB=0 THEN AR=AR+WR*BGR : AG=AG+WG*BGG : AB=AB+WB*BGB : GOTO 1905
1485   REM Save primary-hit state
1490   PROX=ROX : PROY=ROY : PROZ=ROZ
1495   PRDX=RDX : PRDY=RDY : PRDZ=RDZ
1500   PHX=HX : PHY=HY : PHZ=HZ
1505   PNX=NX : PNY=NY : PNZ=NZ
1510   POBJ=HOBJ : PID=HID : PHT=HT
1515   LDX=LX-HX : LDY=LY-HY : LDZ=LZ-HZ
1520   LL=SQR(LDX*LDX+LDY*LDY+LDZ*LDZ) : IF LL>0 THEN LDX=LDX/LL : LDY=LDY/LL : LDZ=LDZ/LL
1525   DL=LL
1530   REM Shadow (ray toward the light)
1535   INSH=0
1540   NDOTL=NX*LDX+NY*LDY+NZ*LDZ
1545   IF NDOTL<=0 THEN INSH=1 : GOTO 1580
1550   SXO=HX+NX*EPS : SYO=HY+NY*EPS : SZO=HZ+NZ*EPS
1555   SDX=LDX : SDY=LDY : SDZ=LDZ
1560   ROX=SXO : ROY=SYO : ROZ=SZO : RDX=SDX : RDY=SDY : RDZ=SDZ
1565   SHAD=1 : GOSUB 1920 : SHAD=0
1570   INSH=0
1575   IF HTB=1 AND HT<DL THEN INSH=1
1580   REM Restore primary-hit state
1585   ROX=PROX : ROY=PROY : ROZ=PROZ
1590   RDX=PRDX : RDY=PRDY : RDZ=PRDZ
1595   HX=PHX : HY=PHY : HZ=PHZ
1600   NX=PNX : NY=PNY : NZ=PNZ
1605   HOBJ=POBJ : HID=PID : HT=PHT
1610   REM Object properties at the hit point
1615   IF HOBJ<>2 THEN 1645 'Plane
1620     IX=INT(HX*TILEI) : IZ=INT(HZ*TILEI)
1625     IP=(ABS(IX) XOR ABS(IZ)) AND 1
1630     IF IP=1 THEN BR=BG=BB=-0.5 ELSE BR=BG=BB=0.45
1635     REFL=PLREFL : TRAN=0 : SEXP=PLSPEC : IOR=1
1640   GOTO 1655
1645     BR=CR(HID) : BG=CG(HID) : BB=CB(HID)
1650     REFL=RF(HID) : TRAN=TR(HID) : SEXP=SP(HID) : IOR=IO(HID)
1655   IF INSH=1 THEN DIF=0 ELSE DIF=NDOTL
1660   SPC1=0
1665   IF INSH<>0 THEN 1685
1670     RVX=2*NDOTL*NX-LDX : RVY=2*NDOTL*NY-LDY : RVZ=2*NDOTL*NZ-LDZ
1675     VDX=-RDX : VDY=-RDY : VDZ=-RDZ
1680     SPC1=RVX*VDX+RVY*VDY+RVZ*VDZ : IF SPC1<=0 THEN SPC1=0 ELSE SPC1=SPC1^SEXP
1685   REM Local colors
1690   LR=BR*(AMB+DIF)+KSP2*SPC1*LCR
1695   LG=BG*(AMB+DIF)+KSP2*SPC1*LCG
1700   LB=BB*(AMB+DIF)+KSP2*SPC1*LCB
1705   REM Reflection direction
1710   DN=RDX*NX+RDY*NY+RDZ*NZ
1715   RFX=RDX-2*DN*NX : RFY=RDY-2*DN*NY : RFZ=RDZ-2*DN*NZ
1720   RORX=HX+NX*EPS : RORY=HY+NY*EPS : RORZ=HZ+NZ*EPS
1725   REM Shared threshold by maximum channel weight
1730   WMAX=WR : IF WG>WMAX THEN WMAX=WG ELSE IF WB>WMAX THEN WMAX=WB
1735   IF TRAN<=0 THEN 1860
1740     REM Transparent: emission = specular highlight; Fresnel mix between reflection AND refraction
1745     ER=SPC1*LCR : EG=SPC1*LCG : EB=SPC1*LCB
1750     OUTS=0 : IF DN<0 THEN OUTS=1
1755     IF OUTS=1 THEN NX=NX : NY=NY : NZ=NZ : I1F=1 : I2F=IOR ELSE NX=-NX : NY=-NY : NZ=-NZ : I1F=IOR : I2F=1
1760     IXV=RDX : IYV=RDY : IZV=RDZ
1765     GOSUB 2075 ' -> RRX,RRY,RRZ, RFAIL
1770     COSI=ABS(DN)
1775     IF RFAIL=1 THEN F=1 ELSE F=R0(HID)+(1-R0(HID))*(1-COSI)^5
1780     ER=KSP*F*SPC1*LCR : EG=KSP*F*SPC1*LCG : EB=KSP*F*SPC1*LCB
1785     AR=AR+WR*ER : AG=AG+WG*EG : AB=AB+WB*EB
1790     CW=F
1795     IF CW<=0 OR CW*WMAX<=WTH THEN 1820
1800       TX=RORX : TY=RORY : TZ=RORZ
1805       UX=RFX : UY=RFY : UZ=RFZ
1810       TCW=CW : TDP=DP
1815       GOSUB 2140
1820     CW=1-F
1825     IF RFAIL<>0 OR DP<=0 OR CW<=0 OR CW*WMAX<=WTH THEN 1905
1830       RORX2=HX-NX*EPS : RORY2=HY-NY*EPS : RORZ2=HZ-NZ*EPS
1835       TX=RORX2 : TY=RORY2 : TZ=RORZ2
1840       UX=RRX : UY=RRY : UZ=RRZ
1845       TCW=CW : TDP=DP
1850       GOSUB 2140
1855   GOTO 1905 'ELSE
1860     REM Opaque: mix (1-REFL)*local + REFL*reflection
1865     ER=(1-REFL)*LR : EG=(1-REFL)*LG : EB=(1-REFL)*LB
1870     AR=AR+WR*ER : AG=AG+WG*EG : AB=AB+WB*EB
1875     CW=REFL
1880     IF CW<=0 OR CW*WMAX<=WTH THEN 1905
1885       TX=RORX : TY=RORY : TZ=RORZ
1890       UX=RFX : UY=RFY : UZ=RFZ
1895       TCW=CW : TDP=DP
1900       GOSUB 2140
1905 WEND 'Next iteration
1910 RETURN
1915 REM INTERSECT SUBROUTINE (RO,RD)
1920 HTB=0 : HT=1E+30 : HOBJ=0 : HID=-1
1925 REM Spheres
1930 FOR I=0 TO NS-1
1935   OCX=ROX-SX(I) : OCY=ROY-SY(I) : OCZ=ROZ-SZ(I)
1940   B=OCX*RDX+OCY*RDY+OCZ*RDZ
1945   OC2=OCX*OCX+OCY*OCY+OCZ*OCZ 'REM OPT
1950   IF B>0 AND OC2>SR2(I) THEN GOTO 2020 'Early rejection
1955   C=OC2-SR2(I) 'Precomputed value
1960   D=B*B-C
1965   IF D<0 THEN 2020
1970     SD=SQR(D)
1975     T1=-B-SD : T2=-B+SD
1980     T=-1
1985     IF T1>EPS THEN T=T1
1990     IF T2>EPS AND (T<0 OR T2<T) THEN T=T2
1995     IF T<=0 OR T>=HT THEN 2020
2000       HT=T : HTB=1 : HOBJ=1 : HID=I
2005       HX=ROX+RDX*T : HY=ROY+RDY*T : HZ=ROZ+RDZ*T
2010       INVSRAD=INVSR(I) 'Precomputed value
2015       NX=(HX-SX(I))*INVSRAD : NY=(HY-SY(I))*INVSRAD : NZ=(HZ-SZ(I))*INVSRAD
2020 NEXT I
2025 REM Plane Y = PLY
2030 IF SHAD=1 THEN 2065
2035 IF ABS(RDY)<=1E-6 THEN 2065
2040   TP=(PLY-ROY)/RDY
2045   IF TP<=EPS OR TP>=HT THEN 2065
2050     HT=TP : HTB=1 : HOBJ=2 : HID=0
2055     HX=ROX+RDX*TP : HY=ROY+RDY*TP : HZ=ROZ+RDZ*TP
2060     NX=0 : NY=1 : NZ=0
2065 RETURN
2070 REM REFRACTION SUBROUTINE
2075 IX=IXV : IY=IYV : IZ=IZV
2080 ETA=I1F/I2F
2085 CI=-(NX*IX+NY*IY+NZ*IZ)
2090 KX=1-ETA*ETA*(1-CI*CI)
2095 IF KX<0 THEN RFAIL=1 : RETURN
2100 SQK = SQR(KX)
2105 TX=ETA*IX+(ETA*CI-SQK)*NX
2110 TY=ETA*IY+(ETA*CI-SQK)*NY
2115 TZ=ETA*IZ+(ETA*CI-SQK)*NZ
2120 REM Do not renormalize T; it should already be unit length
2125 RRX=TX : RRY=TY : RRZ=TZ : RFAIL=0
2130 RETURN
2135 REM ENQUEUE RAY SUBROUTINE
2140 ST=ST+1
2145 ORX(ST)=TX : ORY(ST)=TY : ORZ(ST)=TZ
2150 ODX(ST)=UX : ODY(ST)=UY : ODZ(ST)=UZ
2155 OWR(ST)=WR*TCW : OWG(ST)=WG*TCW : OWB(ST)=WB*TCW
2160 ODP(ST)=TDP-1
2165 RETURN
