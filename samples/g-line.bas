10 REM DARTMOUTH BASIC-COMPATIBLE SCREEN SAVER
20 LET A=0
30 LET X=WIDTH\2
40 LET Y=HEIGHT\2
50 LET D=2
60 LET D1=1.5
70 LET R=100
80 PENWIDTH 4
90 REM MAIN LOOP
100 T1=TIME
110 FOR C=1 TO 1000
120 CLG
130 ORIGIN X,Y
140 LET X1=-R*SIN(A)
150 LET Y1=-R*COS(A)
160 PLOT X1,Y1
170 DRAW 2*R*SIN(A), 2*R*COS(A)
180 FRAME
190 LET A=A+0.04
200 LET X=X+D
210 LET Y=Y+D1
220 IF X>WIDTH-R OR X<R THEN LET D=-D
230 IF Y>HEIGHT-R OR Y<R THEN LET D1=-D1
240 NEXT C
250 PRINT "Elapsed time:";TIME-T1

