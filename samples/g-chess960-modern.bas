100 REM Chess960 starting-position generator - modern AVL BASIC version
105 REM Uses DEF FN, DEF SUB, LOCAL and CALL instead of line-oriented GOSUB blocks.
110 DEF FNSQCOLOR(I)
115   IF I MOD 2=0 THEN FNSQCOLOR=RGB(181,136,99) ELSE FNSQCOLOR=RGB(240,217,181)
120 FNEND
125 DEF FNRANDUNUSED(U)
130   LOCAL I,NFree,Pick
135   NFree=0
140   FOR I=0 TO 7 : IF U(I)=0 THEN NFree=NFree+1
145   NEXT I
150   Pick=INT(RND*NFree)+1 : NFree=0
155   FOR I=0 TO 7
160     IF U(I)=0 THEN NFree=NFree+1:IF NFree=Pick THEN FNRANDUNUSED=I:EXIT FN
165   NEXT I
170   FNRANDUNUSED=0
175 FNEND
180 DEF FNBACKRANK$(P$)
185   LOCAL I
190   FNBACKRANK$=""
195   FOR I=0 TO 7 : FNBACKRANK$=FNBACKRANK$+P$(I) : NEXT I
200 FNEND
205 DEF SUB PUTPIECE(Piece$,X,Y)
210   IF Piece$="B" THEN SPRITE BISHOP$,X,Y,0:EXIT SUB
215   IF Piece$="N" THEN SPRITE KNIGHT$,X,Y,0:EXIT SUB
220   IF Piece$="Q" THEN SPRITE QUEEN$,X,Y,0:EXIT SUB
225   IF Piece$="K" THEN SPRITE KING$,X,Y,0:EXIT SUB
230   IF Piece$="R" THEN SPRITE ROOK$,X,Y,0
235 SUBEND
240 DEF SUB GENERATE(P$,U)
245   LOCAL I,J,Pos
250   FOR I=0 TO 7 : P$(I)="" : U(I)=0 : NEXT I
255   Pos=2*INT(RND*4) : P$(Pos)="B" : U(Pos)=1
260   Pos=1+2*INT(RND*4) : P$(Pos)="B" : U(Pos)=1
265   Pos=FNRANDUNUSED(U) : P$(Pos)="N" : U(Pos)=1
270   Pos=FNRANDUNUSED(U) : P$(Pos)="N" : U(Pos)=1
275   Pos=FNRANDUNUSED(U) : P$(Pos)="Q" : U(Pos)=1
280   J=0
285   FOR I=0 TO 7
290     IF U(I)=0 THEN
295       J=J+1
300       P$(I)=MID$("RKR",J,1) : U(I)=1
305     END IF
310   NEXT I
315 SUBEND
320 DEF SUB DRAWSQUARES(Sq,BaseY)
325   LOCAL I,X
330   FOR I=0 TO 7
335     X=I*Sq
340     FRECTANGLE X,BaseY,X+Sq-1,BaseY+Sq-1,FNSQCOLOR(I)
345     RECTANGLE X,BaseY,X+Sq-1,BaseY+Sq-1,RGB(35,35,38)
350   NEXT I
355 SUBEND
360 DEF SUB DRAWPIECES(P$,Sq,BaseY)
365   LOCAL I,X,Y
370   FOR I=0 TO 7
375     X=I*Sq+(Sq-79)\2 : Y=BaseY+(Sq-79)\2
380     CALL PUTPIECE(P$(I),X,Y)
385   NEXT I
390 SUBEND
395 DEF SUB DRAWLABELS(Sq,Rank$)
400   LOCAL I
405   FOR I=0 TO 7
410     MOVE I*Sq+35,180 : GDISP CHR$(65+I),RGB(210,210,200),-1
415   NEXT I
420   MOVE 20,138 : GDISP "BACK RANK: "+Rank$,RGB(255,255,255),-1
425   MOVE 20,112 : GDISP "BISHOPS ARE ON OPPOSITE COLORS; KING IS BETWEEN BOTH ROOKS.",RGB(210,210,200),-1
430 SUBEND
435 DEF SUB DRAWBOARD(P$,Sq,BaseY)
440   LOCAL Rank$
445   Rank$=FNBACKRANK$(P$)
450   PAPER RGB$(28,29,34) : CLG OFFSCREEN
455   MOVE 20,452 : GDISP "CHESS960 STARTING POSITION",RGB(255,240,200),-1
460   MOVE 20,428 : GDISP "SPACE/ENTER: NEW POSITION     ESC: EXIT",RGB(190,210,230),-1
465   CALL DRAWSQUARES(Sq,BaseY)
470   CALL DRAWPIECES(P$,Sq,BaseY)
475   CALL DRAWLABELS(Sq,Rank$)
480   FRAME
485 SUBEND
490 REM ----- Main program -----
495 SCREEN : MODE 640 : PAPER RGB$(28,29,34) : CLG : SMALLFONT
500 Sq=80 : BaseY=200 : DIM Piece$(7),Used(7)
505 RANDOMIZE TIME
510 BLOAD "assets/bishop.png",BISHOP$
515 BLOAD "assets/knight.png",KNIGHT$
520 BLOAD "assets/queen.png",QUEEN$
525 BLOAD "assets/king.png",KING$
530 BLOAD "assets/rook.png",ROOK$
535 CALL GENERATE(Piece$,Used)
540 CALL DRAWBOARD(Piece$,Sq,BaseY)
545 FRAME
550 IF KEYDOWN(27) THEN SCREEN CLOSE:END
555 K$=INKEY$
560 IF K$="" THEN 550
565 A=ASC(K$)
570 IF A=32 OR A=13 THEN GOTO 535 ELSE 550
