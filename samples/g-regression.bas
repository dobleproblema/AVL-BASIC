100 SCREEN : BIGFONT : MODE 640
110 LOCATE 12,2 : DISP "LINEAR REGRESSION"
120 DIM X(100), Y(100)
130 LET I = 1 : C1 = 0 : C2 = 0 : D1 = 0 : D2 = 0
140 ON ERROR GOTO 190
150 READ Y(I), X(I)
160 LET C1 = C1 + X(I) : C2 = C2 + X(I)^2
170 LET D1 = D1 + Y(I) : D2 = D2 + X(I) * Y(I)
180 PRINT " I = ";I,Y(I);X(I) : I = I + 1 : GOTO 150
190 LET M = I - 1
200 LET A = (M * D2 - C1 * D1) / (M * C2 - C1^2)
210 LET B = (D1 - C1 * A) / M
220 IF ABS(A) < 1E-8 THEN A = 0
230 IF A <> 0 THEN C = -B / A
240 IF ABS(B) < 1E-8 THEN B = 0
250 IF ABS(C) < 1E-8 THEN C = 0
260 INK "white" : BIGFONT
270 LET F$ = STR$(A) + "*X " + MID$("+-", 1-(B<0), 1) + " " + STR$(ABS(B))
280 MOVE 155, 40 : GDISP "Y = " + F$,0,1
290 SCALE 10,80,-112.5,1012.5,40
300 XAXIS 5
310 CROSSAT 10,0 : YAXIS 100,0,900
320 MASK &X00100010 : CROSSAT 10,900 : XAXIS 0 : CROSSAT 10,500 : XAXIS 0 : MASK
330 PENWIDTH 4
340 FOR I = 1 TO M
350 PLOT X(I),Y(I), "yellow"
360 NEXT I
370 MASK &X00001111 : PENWIDTH 2 : INK "red"
380 GRAPH F$
390 DATA 225, 10, 287, 20, 429, 30, 542, 40, 587, 50, 744, 60, 831, 70, 880, 80
400 END

