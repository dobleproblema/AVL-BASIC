100 W=WIDTH : H=HEIGHT
110 NX=W\2 : NY=H\2 : HW=120 : VX=VY=5
120 MinX=MinY=HW : MaxX=W-HW : MaxY=H-HW
130 K0=0
140 SCREEN : CLG
150 X1=NX : Y1=NY
160 R1=R2=F9=0
170 T1=TIME
180 V1=2.4E-2 : V2=3.2E-2
190 DIM T1(8),T2(8)
200 DIM P1(8),P2(8),P3(8)
210 DIM F(6,4)
220 FOR I=1 TO 8 : READ J : P1(I)=J : NEXT I
230 FOR I=1 TO 8 : READ J : P2(I)=J : NEXT I
240 FOR I=1 TO 8 : READ J : P3(I)=J : NEXT I
250 FOR I=1 TO 6
260 FOR J=1 TO 4
270 READ L
280 F(I,J)=L
290 NEXT J
300 NEXT I
310 NX=NX+VX : NY=NY+VY
320 IF NX<MinX THEN NX=MinX+(MinX-NX):VX=-VX
330 IF NX>MaxX THEN NX=MaxX-(NX-MaxX):VX=-VX
340 IF NY<MinY THEN NY=MinY+(MinY-NY):VY=-VY
350 IF NY>MaxY THEN NY=MaxY-(NY-MaxY):VY=-VY
360 ORIGIN 0,0,NX-HW,NX+HW,NY+HW,NY-HW
370 F9 = F9 + 1
380 R1=R1+V1 : R2=R2+V2
390 S1=SIN(R1) : S2=SIN(R2)
400 C1=COS(R1) : C2=COS(R2)
410 FOR I=1 TO 8
420 Y=P2(I)*C1-P3(I)*S1
430 Z=P3(I)*C1+P2(I)*S1
440 X=P1(I)*C2-Z*S2
450 Z=Z*C2+P1(I)*S2-4
460 T1(I)=INT(X*H/Z+X1)
470 T2(I)=INT(Y*H/Z+Y1)
480 NEXT I
490 FOR I=1 TO 6
500 U1=T1(F(I,1)) : U2=T2(F(I,1))
510 U3=T1(F(I,2)) : U4=T2(F(I,2))
520 U5=T1(F(I,3)) : U6=T2(F(I,3))
530 U7=T1(F(I,4)) : U8=T2(F(I,4))
540 Q1=U1-U7 : Q2=U2-U8 : Q3=U1-U3 : Q4=U2-U4
550 Q0=Q1*Q4-Q2*Q3
560 IF Q0<=0 THEN GOTO 640
570 INK I+1
580 FTRIANGLE U1,U2,U3,U4,U5,U6
590 FTRIANGLE U5,U6,U7,U8,U1,U2
600 PENWIDTH 4 : INK 1
610 DRAW NX-HW,NY+HW,NX-HW,NY-HW : DRAW NX+HW,NY-HW : DRAW NX+HW,NY+HW : DRAW NX-HW,NY+HW
620 PENWIDTH 1
630 IF TIME-T1 > 10 THEN PRINT "FPS:"+STR$(F9/10) : F9=0: T1 = TIME
640 NEXT I
650 FRAME : PAUSE 1 : CLG
660 GOTO 310
670 DATA -1, 1, 1, -1, -1, 1, 1, -1
680 DATA 1, 1, -1, -1, 1, 1, -1, -1
690 DATA 1, 1, 1, 1, -1, -1, -1, -1
700 DATA 1, 2, 3, 4
710 DATA 5, 6, 2, 1
720 DATA 8, 7, 6, 5
730 DATA 4, 3, 7, 8
740 DATA 2, 6, 7, 3
750 DATA 5, 1, 4, 8
