1000 REM ============================================================
1005 REM  TUNNEL EFFECT - AVL BASIC
1010 REM  Texture mapping done in BASIC
1015 REM ============================================================
1020 TEXFILE$="assets\tunnel.png"
1025 W=640 : H=480
1030 S=3
1035 NX=(W+S-1)\S : NY=(H+S-1)\S
1040 SM1=S-1 : HS=S/2
1045 SCREEN : MODE 640
1050 PAPER 0 : CLG
1055 DEG
1060 REM LOAD PNG TEXTURE INTO A GRAPHICS STRING
1065 BLOAD TEXFILE$,TEX$
1070 P1=INSTR(TEX$,"x") : P2=INSTR(TEX$,":")
1075 IF P1=0 OR P2=0 THEN PRINT "Formato grafico no valido":END
1080 TW=VAL(LEFT$(TEX$,P1-1))
1085 TH=VAL(MID$(TEX$,P1+1,P2-P1-1))
1090 ITW=1/TW : ITH=1/TH
1095 DIM PIX(TW-1,TH-1)
1100 DIM X0(NX-1),X1(NX-1),Y0(NY-1),Y1(NY-1)
1105 NC=NX*NY
1110 DIM UM(NC-1),VM(NC-1),HM(NC-1)
1115 REM SAMPLE THE TEXTURE ONCE
1120 SPRITE TEX$,0,0
1125 FRAME
1130 FOR J=0 TO TH-1
1135   FOR I=0 TO TW-1
1140     PIX(I,J)=TEST(I,J)
1145   NEXT I
1150 NEXT J
1155 CLG
1160 REM SCREEN BLOCK COORDINATES
1165 FOR I=0 TO NX-1
1170   X0(I)=I*S
1175   X1(I)=X0(I)+SM1
1180   IF X1(I)>W-1 THEN X1(I)=W-1
1185 NEXT I
1190 FOR J=0 TO NY-1
1195   Y0(J)=J*S
1200   Y1(J)=Y0(J)+SM1
1205   IF Y1(J)>H-1 THEN Y1(J)=H-1
1210 NEXT J
1215 REM TUNNEL PARAMETERS
1220 CX=(W-1)/2 : CY=(H-1)/2
1225 UREP=9 : VREP=6
1230 R0=8
1232 HOLE=42
1235 ROTSPD=160
1240 ADVSPD=340
1245 TWU=TW*UREP : THV=TH*VREP
1250 REM PRECALCULATE RADIAL MAP. THE FRAME LOOP ONLY ADDS OFFSETS.
1255 K=0
1260 FOR J=0 TO NY-1
1265   Y=(Y0(J)+Y1(J))/2 : DY=Y-CY
1270   FOR I=0 TO NX-1
1275     X=(X0(I)+X1(I))/2 : DX=X-CX
1280     D=SQR(DX*DX+DY*DY)
1282     IF D<HOLE THEN HM(K)=1:UM(K)=0:VM(K)=0:GOTO 1360
1285     IF DX=0 THEN
1290       IF DY>=0 THEN A=90 ELSE A=270
1295     ELSE
1300       A=ATN(DY/DX)
1305       IF DX<0 THEN A=A+180
1310       IF A<0 THEN A=A+360
1315     END IF
1320     'A=A+22*SIN(D*1.35)
1325     U=TWU*A/360
1330     V=THV*LOG(D+R0)+180/(D+R0)
1335     UI=INT(U) : UI=UI-TW*INT(UI*ITW)
1340     VI=INT(V) : VI=VI-TH*INT(VI*ITH)
1345     IF UI<0 THEN UI=UI+TW
1350     IF VI<0 THEN VI=VI+TH
1355     HM(K)=0 : UM(K)=UI : VM(K)=VI
1360     K=K+1
1365   NEXT I
1370 NEXT J
1375 T0=TIME
1380 FCOUNT=0 : TLAST=TIME : FPS=0
1385 REM MAIN LOOP
1390 T=TIME-T0
1395 UO=INT(T*ROTSPD) : UO=UO-TW*INT(UO*ITW)
1400 VO=INT(T*ADVSPD) : VO=VO-TH*INT(VO*ITH)
1405 K=0
1410 FOR J=0 TO NY-1
1415   YA=Y0(J) : YB=Y1(J)
1420   FOR I=0 TO NX-1
1425     M=HM(K)
1430     IF M=1 THEN GOTO 1440
1435     SI=UM(K)+UO : IF SI>=TW THEN SI=SI-TW
1437     SJ=VM(K)+VO : IF SJ>=TH THEN SJ=SJ-TH
1438     FRECTANGLE X0(I),YA,X1(I),YB,PIX(SI,SJ)
1440     K=K+1
1445   NEXT I
1450 NEXT J
1455 REM OVERLAY
1460 FCOUNT=FCOUNT+1
1465 IF TIME-TLAST>=0.5 THEN
1470   FPS=FCOUNT/(TIME-TLAST)
1475   FCOUNT=0
1480   TLAST=TIME
1485 END IF
1490 SMALLFONT
1495 LOCATE 1,1
1500 DISP "AVL-BASIC TUNNEL TURBO  FPS : "+DEC$(FPS,"###.0")+"  S="+DEC$(S,"#")+"  ESC=SALIR",0,-1
1515 FRAME 60
1520 IF KEYDOWN(27) THEN SCREEN CLOSE:END
1525 GOTO 1390
