10 CLG : T=TIME
20 R=50 : X=WIDTH\2 : Y=HEIGHT\2
25 ORIGIN 0,0,100,WIDTH-100,HEIGHT-100,100
30 FOR CR=1 TO 5000
40 X=RND*WIDTH : Y=RND*HEIGHT : C=RND*32
50 FCIRCLE X,Y,R,C,RND*2
60 X=RND*WIDTH : Y=RND*HEIGHT
70 FRECTANGLE X,Y,X+10+RND*100,Y+10+RND*100,RND*32
80 FRAME : NEXT
90 PRINT "Elapsed time:";TIME-T

