100 REM Classic twisting dot tunnel
110 MODE 800 : SCREEN : PAPER RGB$(42,11,27) : CLG : SMALLFONT
120 DEG
130 CX=WIDTH/2 : CY=HEIGHT/2
140 RINGS=30 : DOTS=30 : STARS=70
150 NEAR=0.7 : FAR=22 : STP=(FAR-NEAR)/RINGS
160 FOC=280 : TUBER=2.35 : SPD=0.19 : T=0
170 DIM Z(RINGS),SX(STARS),SY(STARS),SC(STARS)
180 FOR I=0 TO RINGS-1 : Z(I)=NEAR+I*STP : NEXT I
190 FOR I=1 TO STARS
200   SX(I)=INT(RND*WIDTH) : SY(I)=INT(RND*HEIGHT)
210   SC(I)=RGB(110+INT(RND*145),105+INT(RND*140),120+INT(RND*135))
220 NEXT I
230 FPS=0 : FC=0 : T0=TIME
240 REM Main loop
250 CLG OFFSCREEN
260 FOR I=1 TO STARS : PLOT SX(I),SY(I),SC(I) : NEXT I
270 T=T+1.7
280 CAMW=T+NEAR*14
290 CAMX=1.8*SIN(CAMW)+0.75*SIN(CAMW*2.13)
300 CAMY=1.25*COS(CAMW*0.83)+0.65*SIN(CAMW*1.71)
310 FOR I=0 TO RINGS-1
320   Z(I)=Z(I)-SPD : IF Z(I)<NEAR THEN Z(I)=Z(I)+FAR-NEAR
330   W=T+Z(I)*14
340   PX=1.8*SIN(W)+0.75*SIN(W*2.13)-CAMX
350   PY=1.25*COS(W*0.83)+0.65*SIN(W*1.71)-CAMY
360   Q=1-(Z(I)-NEAR)/(FAR-NEAR)
370   TW=T*2.8+Z(I)*25
380   P=FOC/Z(I)
390   FOR J=0 TO DOTS-1
400     A=J*360/DOTS+TW
410     X3=PX+TUBER*COS(A)
420     Y3=PY+TUBER*SIN(A)
430     X=CX+X3*P
440     Y=CY+Y3*P*0.82
450     IF X<-8 OR X>WIDTH+8 OR Y<-8 OR Y>HEIGHT+8 THEN GOTO 500
460     C=RGB(INT(110+145*Q),INT(96+150*Q),INT(122+130*Q))
470     IF J MOD 4=0 THEN C=RGB(INT(150+105*Q),INT(118+135*Q),INT(86+125*Q))
480     SZ=INT(1+2.3*Q)
490     FRECTANGLE X-SZ,Y-SZ,X+SZ,Y+SZ,C
500   NEXT J
510 NEXT I
520 FC=FC+1 : IF TIME-T0>=0.5 THEN FPS=FC/(TIME-T0):FC=0:T0=TIME
530 DISP "AVL-BASIC TWISTING DOT TUNNEL  FPS: "+DEC$(FPS,"###.0")+"  ESC=EXIT",14
540 FRAME 60
550 IF KEYDOWN(27) THEN SCREEN CLOSE:END
560 GOTO 250
