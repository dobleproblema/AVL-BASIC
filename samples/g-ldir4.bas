10 CLG : BIGFONT : DEG
20 T$="COPYRIGHT 2025 JOSE ANTONIO AVILA - "
30 T1=T2=P1=P2=1 : L=LEN(T$)
40 CLG
50 FOR X=T1 TO 360+T1 STEP 10
60 MOVE WIDTH\2+SIN(X)*200,HEIGHT\2+COS(X)*200
70 C$=MID$(T$,P1,1)
80 P1=(P1+1) MOD L
90 LDIR -X : GDISP C$
100 NEXT
110 FOR X=T2 TO 360+T2 STEP 10
120 MOVE WIDTH\2+SIN(X)*100,HEIGHT\2+COS(X)*100
130 C$=MID$(T$,P2,1)
140 P2=(P2+1) MOD L
150 LDIR -X : GDISP C$,1,-1
160 NEXT
170 FRAME 60 : T1=T1+9 : T2=T2+6
180 GOTO 40

