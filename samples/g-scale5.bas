10 DEF FNX(X)=1/X
15 SCREEN : CLG
20 SCALE -10,2,-10,2,50
25 XAXIS -1,-8.5,0,1
30 YAXIS -1,-8.5,0,1
35 CROSSAT 0,2 : XAXIS 0 : CROSSAT 0,-10 : XAXIS 0
40 CROSSAT 2,0 : YAXIS 0 : CROSSAT -10,0 : YAXIS 0
45 INK 2 : PENWIDTH 4
50 MOVE -8.5,FNX(-8.5)
55 FOR X=-8.5 TO 0 STEP 0.003
60 Y=FNX(X) : IF Y>-8.5 THEN DRAW X,Y
65 NEXT

